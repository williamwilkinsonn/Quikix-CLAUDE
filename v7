// REACTION BAR  (Fix #5: correct key mapping)
// ═══════════════════════════════════════════════════════════════════════════════
const ReactionBar = memo(function ReactionBar({ postId, initial={} }) {
  const { D } = useTheme();
  const initCounts = useMemo(() => {
    const base = { heart:0, fire:0, haha:0, wow:0, clap:0 };
    // Fix #5: map by r.key not r.emoji
    REACTIONS.forEach(r => { if (initial[r.key]) base[r.key] = initial[r.key]; });
    return base;
  }, []);
  const [counts, setCounts] = useState(initCounts);
  const [mine, setMine] = useState(null);
  const [burst, setBurst] = useState(null);

  const tap = useCallback((key) => {
    // Fix #7: haptic feedback
    try { navigator.vibrate && navigator.vibrate(8); } catch {}
    if (mine === key) { setCounts(c=>({...c,[key]:Math.max(0,c[key]-1)})); setMine(null); return; }
    if (mine) setCounts(c=>({...c,[mine]:Math.max(0,c[mine]-1)}));
    setCounts(c=>({...c,[key]:c[key]+1}));
    setMine(key); setBurst(key);
    setTimeout(()=>setBurst(null), 600);
  }, [mine]);

  return (
    <div style={{ display:"flex", gap:5, alignItems:"center" }} role="group" aria-label="Reactions">
      {REACTIONS.map(r => {
        const active = mine===r.key, n = counts[r.key];
        return (
          <button key={r.key} onClick={()=>tap(r.key)} aria-label={`${r.label}${n>0?`, ${n}`:""}`} aria-pressed={active}
            style={{ display:"flex", alignItems:"center", gap:3, padding:"5px 8px", borderRadius:50, border:`1.5px solid ${active?B.pink:D.border}`, background:active?`${B.pink}18`:D.surface, cursor:"pointer", transform:burst===r.key?"scale(1.4)":"scale(1)", transition:"all .18s cubic-bezier(.34,1.56,.64,1)" }}>
