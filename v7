  return (
    <div style={{ position:"fixed",inset:0,zIndex:600,background:B.grad,display:"flex",flexDirection:"column" }} role="dialog" aria-modal="true">
      <div style={{ padding:"18px 20px 12px",display:"flex",alignItems:"center",justifyContent:"space-between",flexShrink:0 }}>
        <button onClick={onClose} style={{ background:"none",border:"none",color:"rgba(255,255,255,0.85)",fontSize:15,cursor:"pointer",fontFamily:FONT,fontWeight:700 }}>Cancel</button>
        <Logo size={26} white/>
        <div style={{ width:60 }}/>
      </div>
      <h2 style={{ fontFamily:FONT,fontWeight:900,fontSize:22,color:"#fff",margin:"0 0 16px",textAlign:"center",flexShrink:0 }}>Choose Poll Format</h2>
      <div style={{ flex:1,overflowY:"auto",padding:"0 18px 40px" }}>
        <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:12 }}>
          {POLL_TYPES.map(f=>(
            <button key={f.id} onClick={()=>onSelect(f.id)} aria-label={`Create ${f.label} poll`}
              style={{ background:"rgba(255,255,255,0.15)",backdropFilter:"blur(10px)",border:"1.5px solid rgba(255,255,255,0.25)",borderRadius:18,padding:"18px 14px",cursor:"pointer",textAlign:"left",transition:"all .15s" }}>
              <div style={{ fontSize:30,marginBottom:8 }}>{f.icon}</div>
              <div style={{ fontFamily:FONT,fontWeight:800,fontSize:14,color:"#fff",marginBottom:4 }}>{f.label}</div>
              <div style={{ fontFamily:FONT,fontSize:11,color:"rgba(255,255,255,0.75)",lineHeight:1.4 }}>{f.desc}</div>
            </button>
          ))}
        </div>
      </div>
    </div>
  );
}

function CreatePost({ format, user, onPublish, onClose }) {
  const [question,setQuestion]=useState("");
  const [tags,setTags]=useState("");
  const [hours,setHours]=useState(24);
  const [images,setImages]=useState([]);
  const [bg,setBg]=useState(user.brandColor||"#F4C4C0");
  const [textColor,setTextColor]=useState("#1A2154");
  const [options,setOptions]=useState(["Option A","Option B","Option C"]);
  const [dirty,setDirty]=useState(false);
  const blobUrls=useRef([]);
  const imgRef=useRef();
  const ft=POLL_TYPES.find(t=>t.id===format)||POLL_TYPES[0];
  const needsImages=["ab","image4","video"].includes(format);
  const needsOptions=["multi","ranked"].includes(format);
  const maxImg=format==="ab"?2:format==="image4"?4:1;
  const bgs=["#F4C4C0","#C4DDF4","#D4F4C4","#F4ECC4","#E8C4F4","#1A2154","#000","#E8F5E9"];

  useEffect(()=>{return()=>blobUrls.current.forEach(u=>URL.revokeObjectURL(u));},[]);

  const handleImg=e=>{
    const files=Array.from(e.target.files).slice(0,maxImg-images.length);
    const ni=files.map(f=>{const url=URL.createObjectURL(f);blobUrls.current.push(url);return{url};});
    setImages(imgs=>[...imgs,...ni].slice(0,maxImg));
    setDirty(true);
  };
  const removeImg=i=>{URL.revokeObjectURL(images[i].url);blobUrls.current=blobUrls.current.filter(u=>u!==images[i].url);setImages(imgs=>imgs.filter((_,j)=>j!==i));};

  const handleCancel=()=>{
    if((dirty||question)&&!window.confirm("Discard this poll?"))return;
    blobUrls.current.forEach(u=>URL.revokeObjectURL(u));
    onClose();
  };

  const publish=()=>{
    if(!question.trim())return;
    blobUrls.current=[];
    const baseVotes=needsOptions?options.map(()=>0):format==="slider"?Array(10).fill(0):[0,0];
    onPublish({
      id:uid(), type:format, authorId:"me", question,
      tags:tags.split(/\s+/).filter(Boolean).map(t=>t.startsWith("#")?t:`#${t}`),
      endsAt:Date.now()+hours*3600000,
      images:images.length>0?images.map(i=>i.url):undefined,
      bg, textColor,
      options:needsOptions?options:undefined,
      votes:baseVotes, userVote:null,
      comments:[], reactions:{heart:0,fire:0,haha:0,wow:0,clap:0},
      views:0, shares:0, trending:false,
    });
    onClose();
  };

  return (
    <div style={{ position:"fixed",inset:0,zIndex:550,background:B.white,overflowY:"auto" }} role="dialog" aria-modal="true">
      <div style={{ padding:"14px 18px",borderBottom:`1px solid ${B.border}`,display:"flex",alignItems:"center",justifyContent:"space-between",position:"sticky",top:0,background:B.white,zIndex:10 }}>
        <button onClick={handleCancel} style={{ background:"none",border:"none",fontFamily:FONT,fontSize:15,color:B.textMid,cursor:"pointer" }}>Cancel</button>
        <Logo size={24}/>
        <button onClick={publish} disabled={!question.trim()} style={{ background:question.trim()?(user.brandColor?grad(user.brandColor,B.orange):B.grad):B.light,border:"none",borderRadius:20,padding:"8px 20px",fontFamily:FONT,fontWeight:800,fontSize:14,color:question.trim()?"#fff":B.textMid,cursor:question.trim()?"pointer":"not-allowed" }}>Post</button>
      </div>
      <div style={{ padding:"20px 20px 120px" }}>
        <div style={{ display:"inline-flex",alignItems:"center",gap:8,background:user.brandColor?grad(user.brandColor,B.orange):B.grad,borderRadius:20,padding:"6px 16px",marginBottom:20 }}>
          <span style={{ fontSize:16 }}>{ft.icon}</span>
          <span style={{ color:"#fff",fontSize:13,fontWeight:800,fontFamily:FONT }}>{ft.label}</span>
        </div>

        <div style={{ marginBottom:16 }}>
          <label htmlFor="cq" style={{ display:"block",fontFamily:FONT,fontWeight:700,fontSize:11,color:B.textMid,marginBottom:6,letterSpacing:0.8 }}>YOUR QUESTION</label>
          <textarea id="cq" value={question} onChange={e=>{setQuestion(e.target.value);setDirty(true);}} placeholder="Ask something…" rows={3} style={{ width:"100%",border:`1.5px solid ${B.border}`,borderRadius:14,padding:"13px 15px",fontFamily:FONT,fontSize:15,color:B.navy,outline:"none",resize:"none",background:B.offWhite,boxSizing:"border-box" }}/>
        </div>

        {needsImages&&(
          <div style={{ marginBottom:18 }}>
            <p style={{ fontFamily:FONT,fontWeight:700,fontSize:11,color:B.textMid,marginBottom:8,marginTop:0,letterSpacing:0.8 }}>
              {format==="ab"?"A vs B IMAGES (2 required)":format==="image4"?"4 OPTION IMAGES":"MEDIA"}
            </p>
            <div style={{ display:"flex",gap:10,flexWrap:"wrap" }}>
              {images.map((img,i)=>(
                <div key={i} style={{ width:90,height:90,borderRadius:14,overflow:"hidden",position:"relative",border:`1.5px solid ${B.border}` }}>
                  <img src={img.url} alt={`Image ${i+1}`} loading="lazy" style={{ width:"100%",height:"100%",objectFit:"cover" }}/>
                  <div style={{ position:"absolute",top:4,left:6,fontFamily:FONT,fontWeight:900,fontSize:11,color:"#fff",textShadow:"0 1px 3px rgba(0,0,0,0.8)" }}>{String.fromCharCode(65+i)}</div>
                  <button onClick={()=>removeImg(i)} style={{ position:"absolute",top:4,right:4,background:"rgba(0,0,0,0.7)",border:"none",color:"#fff",borderRadius:"50%",width:20,height:20,cursor:"pointer",fontSize:11 }}>✕</button>
                </div>
              ))}
              {images.length<maxImg&&<button onClick={()=>imgRef.current?.click()} style={{ width:90,height:90,borderRadius:14,border:`2px dashed ${user.brandColor||B.pink}`,background:B.offWhite,cursor:"pointer",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",gap:4,color:user.brandColor||B.pink }}>
                <span style={{ fontSize:26 }}>+</span><span style={{ fontFamily:FONT,fontSize:10,fontWeight:700 }}>Add</span>
              </button>}
              <input ref={imgRef} type="file" accept={format==="video"?"video/*":"image/*"} multiple style={{ display:"none" }} onChange={handleImg}/>
            </div>
          </div>
        )}

        {format==="text"&&(
          <div style={{ marginBottom:18 }}>
            <p style={{ fontFamily:FONT,fontWeight:700,fontSize:11,color:B.textMid,marginBottom:8,marginTop:0,letterSpacing:0.8 }}>BACKGROUND COLOR</p>
            <div style={{ display:"flex",gap:10,flexWrap:"wrap",marginBottom:10 }}>{bgs.map(c=><button key={c} onClick={()=>setBg(c)} style={{ width:40,height:40,borderRadius:"50%",background:c,border:bg===c?`3px solid ${B.navy}`:`2px solid ${B.border}`,cursor:"pointer" }}/>)}</div>
            <div style={{ display:"flex",gap:10,alignItems:"center" }}>
              <span style={{ fontFamily:FONT,fontSize:12,color:B.textMid,fontWeight:600 }}>Text color:</span>
              {["#1A2154","#FFFFFF","#E8407A","#F5A623"].map(c=><button key={c} onClick={()=>setTextColor(c)} style={{ width:30,height:30,borderRadius:"50%",background:c,border:textColor===c?`3px solid ${B.navy}`:`2px solid ${B.border}`,cursor:"pointer" }}/>)}
            </div>
          </div>
        )}

        {format==="slider"&&(
          <div style={{ marginBottom:18,background:B.offWhite,borderRadius:14,padding:"14px 16px" }}>
            <p style={{ fontFamily:FONT,fontWeight:700,fontSize:11,color:B.textMid,margin:"0 0 8px",letterSpacing:0.8 }}>SCALE PREVIEW</p>
            <div style={{ display:"flex",justifyContent:"space-between" }}>
              <span style={{ fontFamily:FONT,fontSize:12,color:B.textMid }}>1 — Low</span>
              <span style={{ fontFamily:FONT,fontWeight:900,fontSize:20,color:user.brandColor||B.pink }}>1–10</span>
              <span style={{ fontFamily:FONT,fontSize:12,color:B.textMid }}>10 — High</span>
            </div>
          </div>
        )}

        {needsOptions&&(
          <div style={{ marginBottom:18 }}>
            <p style={{ fontFamily:FONT,fontWeight:700,fontSize:11,color:B.textMid,marginBottom:8,marginTop:0,letterSpacing:0.8 }}>
              {format==="ranked"?"OPTIONS TO RANK":"ANSWER OPTIONS"}
            </p>
            {options.map((opt,i)=>(
              <div key={i} style={{ display:"flex",gap:8,marginBottom:8,alignItems:"center" }}>
                <div style={{ width:28,height:28,borderRadius:8,background:B.grad,display:"flex",alignItems:"center",justifyContent:"center",fontFamily:FONT,fontWeight:900,fontSize:12,color:"#fff",flexShrink:0 }}>{i+1}</div>
                <input value={opt} onChange={e=>{const o=[...options];o[i]=e.target.value;setOptions(o);}} style={{ flex:1,border:`1.5px solid ${B.border}`,borderRadius:10,padding:"10px 12px",fontFamily:FONT,fontSize:13,color:B.navy,outline:"none",background:B.offWhite }}/>
                {options.length>2&&<button onClick={()=>setOptions(o=>o.filter((_,j)=>j!==i))} style={{ background:"none",border:"none",color:B.textGray,cursor:"pointer",fontSize:18,padding:0,flexShrink:0 }}>✕</button>}
              </div>
            ))}
            {options.length<(format==="ranked"?6:6)&&(
              <button onClick={()=>setOptions(o=>[...o,`Option ${o.length+1}`])} style={{ width:"100%",padding:"10px 0",border:`1.5px dashed ${B.border}`,borderRadius:10,background:"transparent",fontFamily:FONT,fontSize:13,color:B.textMid,cursor:"pointer" }}>+ Add Option</button>
            )}
          </div>
        )}

        <div style={{ marginBottom:16 }}>
          <label htmlFor="ct" style={{ display:"block",fontFamily:FONT,fontWeight:700,fontSize:11,color:B.textMid,marginBottom:6,letterSpacing:0.8 }}>HASHTAGS</label>
          <input id="ct" value={tags} onChange={e=>setTags(e.target.value)} placeholder="#fashion #beauty" style={{ width:"100%",border:`1.5px solid ${B.border}`,borderRadius:14,padding:"12px 14px",fontFamily:FONT,fontSize:14,color:user.brandColor||B.pink,outline:"none",background:B.offWhite,boxSizing:"border-box" }}/>
        </div>

        <div style={{ marginBottom:20 }}>
          <p style={{ fontFamily:FONT,fontWeight:700,fontSize:11,color:B.textMid,marginBottom:8,marginTop:0,letterSpacing:0.8 }}>POLL DURATION</p>
          <div style={{ display:"flex",gap:8 }}>
            {[1,6,12,24,48,72].map(h=><button key={h} onClick={()=>setHours(h)} aria-pressed={hours===h} style={{ flex:1,padding:"10px 0",borderRadius:10,border:`2px solid ${hours===h?user.brandColor||B.pink:B.border}`,background:hours===h?`${user.brandColor||B.pink}15`:B.offWhite,color:hours===h?user.brandColor||B.pink:B.textMid,fontFamily:FONT,fontWeight:700,fontSize:12,cursor:"pointer" }}>{h}h</button>)}
          </div>
        </div>

        {question&&<div style={{ borderRadius:16,overflow:"hidden",border:`1.5px solid ${B.border}` }}>
          <div style={{ padding:"8px 14px",background:B.offWhite,fontFamily:FONT,fontSize:11,fontWeight:700,color:B.textMid,letterSpacing:0.5 }}>PREVIEW</div>
          <div style={{ background:format==="text"?bg:B.white,padding:"18px 16px",textAlign:"center",minHeight:70,display:"flex",alignItems:"center",justifyContent:"center" }}>
            <p style={{ fontFamily:FONT,fontWeight:700,fontSize:15,color:format==="text"?textColor:B.navy,margin:0 }}>{question}</p>
          </div>
        </div>}
      </div>
    </div>
  );
}

function ShareSheet({ post, onClose }) {
  const [copied,setCopied]=useState(false);
  const url=`https://quikix.com/q/${post?.id}`;
  const handleCopy=()=>{try{navigator.clipboard.writeText(url);}catch{}setCopied(true);setTimeout(()=>setCopied(false),2000);};
  return (
    <div style={{ position:"fixed",inset:0,zIndex:700,background:"rgba(0,0,0,0.6)",display:"flex",alignItems:"flex-end" }} role="dialog" aria-modal="true" onClick={e=>e.target===e.currentTarget&&onClose()}>
      <div style={{ background:"#2C2C2E",borderRadius:"22px 22px 0 0",width:"100%",padding:"18px 20px 44px" }}>
        <div style={{ width:40,height:4,background:"#555",borderRadius:2,margin:"0 auto 18px" }}/>
        <h2 style={{ fontFamily:FONT,fontWeight:900,fontSize:20,color:"#fff",marginBottom:6,marginTop:0 }}>Share Poll</h2>
        <p style={{ fontFamily:FONT,fontSize:13,color:"#aaa",marginBottom:20,wordBreak:"break-all",marginTop:0 }}>{url}</p>
        {typeof navigator!=="undefined"&&navigator.share&&<button onClick={async()=>{try{await navigator.share({title:"Quikix",text:post?.question,url});onClose();}catch{}}} style={{ width:"100%",padding:"14px 0",background:B.grad,border:"none",borderRadius:14,fontFamily:FONT,fontWeight:800,fontSize:15,color:"#fff",cursor:"pointer",marginBottom:12 }}>Share via…</button>}
        <div style={{ display:"flex",gap:14,overflowX:"auto",paddingBottom:8,marginBottom:18,scrollbarWidth:"none" }}>
          {[["📋","Copy",handleCopy],["💬","SMS",null],["📘","Facebook",null],["🐦","X",null],["📸","Instagram",null],["✉️","Email",null]].map(([icon,label,action],i)=>(
            <button key={i} onClick={action||undefined} style={{ display:"flex",flexDirection:"column",alignItems:"center",gap:6,background:"none",border:"none",cursor:"pointer",flexShrink:0 }}>
              <div style={{ width:56,height:56,borderRadius:16,background:"#3A3A3C",display:"flex",alignItems:"center",justifyContent:"center",fontSize:22 }}>{label==="Copy"&&copied?"✓":icon}</div>
              <span style={{ fontFamily:FONT,fontSize:11,color:"#fff" }}>{label==="Copy"&&copied?"Copied!":label}</span>
            </button>
          ))}
        </div>
        <button onClick={onClose} style={{ width:"100%",padding:"16px 0",background:"#3A3A3C",border:"none",borderRadius:14,fontFamily:FONT,fontWeight:700,fontSize:16,color:"#fff",cursor:"pointer" }}>Cancel</button>
      </div>
    </div>
  );
}

