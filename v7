// MESSAGES  (Fix #18: functional chat thread)
// ═══════════════════════════════════════════════════════════════════════════════
function MessagesPage() {
  const { D } = useTheme();
  const [active,setActive]=useState(null);
  const [msgText,setMsgText]=useState("");
  const [threads,setThreads]=useState({
    hm:[{id:1,from:"hm",text:"Thanks for voting on our poll! 💕",time:"2m"},{id:2,from:"me",text:"Love your new collection!",time:"1m"}],
    loreal:[{id:1,from:"loreal",text:"Check out our new foundation poll!",time:"1h"}],
    fash:[{id:1,from:"fash",text:"Love your jeans poll 👖",time:"3h"}],
  });
  const convos=[{id:"hm",name:"H&M",avatar:"H",color:"#E50010",unread:2},{id:"loreal",name:"L'Oréal Paris",avatar:"L",color:"#C4A55A",unread:0},{id:"fash",name:"Fashionista",avatar:"F",color:B.purple,unread:1}];

  const send=()=>{
    if(!msgText.trim()||!active)return;
    setThreads(t=>({...t,[active]:[...t[active],{id:Date.now(),from:"me",text:msgText,time:"Just now"}]}));
    setMsgText("");
  };

  if(active){
    const u=USERS[active]||USERS.me;
    const msgs=threads[active]||[];
    return (
      <div style={{ display:"flex",flexDirection:"column",height:"calc(100vh - 56px - 72px)" }}>
        <div style={{ padding:"12px 16px",borderBottom:`1px solid ${D.border}`,display:"flex",alignItems:"center",gap:12,background:D.card }}>
          <button onClick={()=>setActive(null)} style={{ background:"none",border:"none",fontSize:20,cursor:"pointer",color:D.textMid }}>←</button>
          <div style={{ width:38,height:38,borderRadius:"50%",background:u.brandColor,display:"flex",alignItems:"center",justifyContent:"center",fontFamily:FONT,fontWeight:900,fontSize:14,color:"#fff" }}>{u.avatar}</div>
          <div><div style={{ fontFamily:FONT,fontWeight:800,fontSize:15,color:D.text }}>{u.name}</div><div style={{ fontFamily:FONT,fontSize:11,color:B.green }}>● Active</div></div>
        </div>
        <div style={{ flex:1,overflowY:"auto",padding:"16px",display:"flex",flexDirection:"column",gap:10 }}>
          {msgs.map(m=>{
            const isMe=m.from==="me";
            return (
              <div key={m.id} style={{ display:"flex",justifyContent:isMe?"flex-end":"flex-start" }}>
                <div style={{ maxWidth:"75%",background:isMe?u.brandColor:D.surface,color:isMe?"#fff":D.text,padding:"10px 14px",borderRadius:isMe?"18px 18px 4px 18px":"18px 18px 18px 4px",fontFamily:FONT,fontSize:14,lineHeight:1.4 }}>
                  {m.text}
                  <div style={{ fontSize:10,color:isMe?"rgba(255,255,255,0.7)":D.textGray,marginTop:3,textAlign:"right" }}>{m.time}</div>
                </div>
              </div>
            );
          })}
        </div>
        <div style={{ padding:"12px 16px",borderTop:`1px solid ${D.border}`,display:"flex",gap:10,background:D.card }}>
          <input value={msgText} onChange={e=>setMsgText(e.target.value)} onKeyDown={e=>e.key==="Enter"&&send()} placeholder="Message…" style={{ flex:1,border:`1.5px solid ${D.border}`,borderRadius:50,padding:"10px 16px",fontFamily:FONT,fontSize:14,outline:"none",background:D.surface,color:D.text }}/>
          <button onClick={send} style={{ width:42,height:42,borderRadius:"50%",background:u.brandColor,border:"none",cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",color:"#fff" }}><Ic.Send/></button>
        </div>
      </div>
    );
  }

  return (
    <div style={{ paddingBottom:100 }}>
      <div style={{ padding:"18px 18px 12px",display:"flex",alignItems:"center",justifyContent:"space-between" }}>
        <h2 style={{ fontFamily:FONT,fontWeight:900,fontSize:20,color:D.text,margin:0 }}>Messages</h2>
        <button style={{ width:36,height:36,borderRadius:"50%",background:B.grad,border:"none",cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",color:"#fff",fontSize:18 }}>✎</button>
      </div>
      <div style={{ padding:"0 16px 14px" }}>
        <input placeholder="Search messages…" style={{ width:"100%",border:`1.5px solid ${D.border}`,borderRadius:50,padding:"11px 16px",fontFamily:FONT,fontSize:14,color:D.text,outline:"none",background:D.surface,boxSizing:"border-box" }}/>
      </div>
      {convos.map(c=>(
        <div key={c.id} onClick={()=>setActive(c.id)} style={{ display:"flex",gap:13,padding:"14px 18px",borderBottom:`1px solid ${D.border}`,cursor:"pointer",background:D.card }}>
          <div style={{ width:50,height:50,borderRadius:"50%",background:c.color,display:"flex",alignItems:"center",justifyContent:"center",fontFamily:FONT,fontWeight:900,fontSize:18,color:"#fff",flexShrink:0,position:"relative" }}>
            {c.avatar}
            {c.unread>0&&<div style={{ position:"absolute",top:0,right:0,width:18,height:18,background:B.pink,borderRadius:"50%",display:"flex",alignItems:"center",justifyContent:"center",border:`2px solid ${D.card}` }}><span style={{ fontFamily:FONT,fontWeight:900,fontSize:9,color:"#fff" }}>{c.unread}</span></div>}
          </div>
          <div style={{ flex:1,minWidth:0 }}>
            <div style={{ display:"flex",justifyContent:"space-between",marginBottom:4 }}>
              <span style={{ fontFamily:FONT,fontWeight:800,fontSize:15,color:D.text }}>{c.name}</span>
