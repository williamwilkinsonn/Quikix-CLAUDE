          {!isClosed&&<>
            <div style={{ position:"absolute",bottom:14,left:16 }}><button onClick={e=>{e.stopPropagation();vote(1);}} disabled={voted!==null} aria-label="Vote No" style={{ width:52,height:52,borderRadius:"50%",background:"rgba(255,255,255,0.2)",backdropFilter:"blur(8px)",border:"2px solid rgba(255,255,255,0.4)",cursor:voted!==null?"default":"pointer",fontSize:22,display:"flex",alignItems:"center",justifyContent:"center",opacity:voted!==null&&voted!==1?0.45:1 }}>👎</button></div>
            <div style={{ position:"absolute",bottom:14,right:16 }}><button onClick={e=>{e.stopPropagation();vote(0);}} disabled={voted!==null} aria-label="Vote Yes" style={{ width:52,height:52,borderRadius:"50%",background:"rgba(255,255,255,0.2)",backdropFilter:"blur(8px)",border:"2px solid rgba(255,255,255,0.4)",cursor:voted!==null?"default":"pointer",fontSize:22,display:"flex",alignItems:"center",justifyContent:"center",opacity:voted!==null&&voted!==0?0.45:1 }}>👍</button></div>
          </>}
        </div>
      )}

      {/* ── Multiple Choice ── */}
      {post.type==="multi"&&post.options&&(
        <div style={{ padding:"0 16px 12px" }}>
          {post.options.map((opt,i)=>{
            const v=lv[i]||0, vPct=pct(v,totalVotes), isWinner=voted!==null&&(lv[i]||0)===Math.max(...lv);
            return (
              <button key={i} onClick={()=>vote(i)} disabled={voted!==null||isClosed}
                style={{ width:"100%",marginBottom:8,padding:"11px 14px",border:`2px solid ${voted===i?ac:D.border}`,borderRadius:12,background:D.surface,cursor:voted!==null||isClosed?"default":"pointer",textAlign:"left",position:"relative",overflow:"hidden",transition:"border-color .15s" }}>
                {voted!==null&&<div style={{ position:"absolute",inset:0,width:`${vPct}%`,background:voted===i?`${ac}20`:`${D.border}77`,transition:"width .8s ease",borderRadius:10 }}/>}
                <div style={{ position:"relative",display:"flex",alignItems:"center",justifyContent:"space-between",gap:8 }}>
                  <div style={{ display:"flex",alignItems:"center",gap:9 }}>
                    <div style={{ width:22,height:22,borderRadius:"50%",border:`2px solid ${voted===i?ac:D.border}`,background:voted===i?ac:"transparent",display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0 }}>
                      {voted===i&&<span style={{ fontSize:11,color:"#fff" }}>✓</span>}
                    </div>
                    <span style={{ fontFamily:FONT,fontWeight:voted===i?800:600,fontSize:14,color:D.text }}>{opt}</span>
                  </div>
                  {voted!==null&&<span style={{ fontFamily:FONT,fontWeight:800,fontSize:13,color:isWinner?ac:D.textMid,flexShrink:0 }}>{vPct}%</span>}
                </div>
              </button>
            );
          })}
          {voted!==null&&<div style={{ fontFamily:FONT,fontSize:12,color:D.textMid,textAlign:"center",marginTop:4 }}>{fmt(totalVotes)} total votes</div>}
        </div>
      )}

      {/* ── Slider Scale ── */}
      {post.type==="slider"&&(
        <div style={{ padding:"10px 20px 16px" }}>
          <div style={{ display:"flex",justifyContent:"space-between",marginBottom:8 }}>
            <span style={{ fontFamily:FONT,fontSize:12,color:D.textMid }}>1 — Not at all</span>
            <span style={{ fontFamily:FONT,fontSize:12,color:D.textMid }}>10 — Absolutely!</span>
          </div>
          <input type="range" min={1} max={10} value={sliderVal} onChange={e=>setSliderVal(parseInt(e.target.value))} disabled={voted!==null||isClosed}
            style={{ width:"100%",accentColor:ac,cursor:voted!==null||isClosed?"default":"pointer",marginBottom:12 }}/>
          <div style={{ textAlign:"center",marginBottom:14 }}>
            <span style={{ fontFamily:FONT,fontWeight:900,fontSize:40,color:ac,lineHeight:1 }}>{sliderVal}</span>
            <span style={{ fontFamily:FONT,fontSize:14,color:D.textMid }}> / 10</span>
          </div>
          {voted===null&&!isClosed&&(
            <button onClick={()=>vote(sliderVal-1)} style={{ width:"100%",padding:"12px 0",borderRadius:50,background:grad(ac,B.orange),border:"none",fontFamily:FONT,fontWeight:800,fontSize:14,color:"#fff",cursor:"pointer" }}>Submit Rating</button>
          )}
          {voted!==null&&lv.length===10&&(
            <div>
              <div style={{ fontFamily:FONT,fontWeight:600,fontSize:12,color:D.textMid,marginBottom:8 }}>Response distribution ({fmt(totalVotes)} ratings)</div>
              <div style={{ display:"flex",gap:3,alignItems:"flex-end",height:56 }}>
                {lv.map((v,i)=>{
                  const maxV=Math.max(...lv,1);
                  return <div key={i} style={{ flex:1,background:i===sliderVal-1?ac:`${ac}40`,borderRadius:"4px 4px 0 0",height:`${Math.max(6,(v/maxV)*56)}px`,transition:"height .5s ease",position:"relative" }}>
                    {i===sliderVal-1&&<div style={{ position:"absolute",top:-16,left:"50%",transform:"translateX(-50%)",fontFamily:FONT,fontSize:8,fontWeight:900,color:ac,whiteSpace:"nowrap" }}>Your pick</div>}
                  </div>;
                })}
              </div>
              <div style={{ display:"flex",justifyContent:"space-between",marginTop:4 }}>
                {[1,5,10].map(n=><span key={n} style={{ fontFamily:FONT,fontSize:9,color:D.textGray }}>{n}</span>)}
              </div>
            </div>
          )}
        </div>
      )}

      {/* ── Ranked Choice ── */}
      {post.type==="ranked"&&post.options&&(
        <div style={{ padding:"0 16px 12px" }}>
          {voted===null&&!rankDone?(
            <>
              <p style={{ fontFamily:FONT,fontSize:12,color:D.textMid,margin:"0 0 10px" }}>Tap ▲▼ to reorder, then submit your ranking</p>
              {rankItems.map((item,i)=>(
                <div key={item} style={{ display:"flex",alignItems:"center",gap:10,padding:"10px 12px",background:D.surface,borderRadius:12,marginBottom:8,border:`1.5px solid ${D.border}` }}>
                  <div style={{ width:28,height:28,borderRadius:8,background:B.grad,display:"flex",alignItems:"center",justifyContent:"center",fontFamily:FONT,fontWeight:900,fontSize:13,color:"#fff",flexShrink:0 }}>{i+1}</div>
                  <span style={{ fontFamily:FONT,fontWeight:700,fontSize:14,color:D.text,flex:1 }}>{item}</span>
                  <div style={{ display:"flex",flexDirection:"column",gap:4 }}>
                    <button onClick={()=>{ if(i===0)return; const a=[...rankItems];[a[i-1],a[i]]=[a[i],a[i-1]];setRankItems(a); }} disabled={i===0}
                      style={{ background:"none",border:"none",cursor:i===0?"not-allowed":"pointer",color:i===0?D.textGray:ac,fontSize:13,padding:0,lineHeight:1 }}>▲</button>
                    <button onClick={()=>{ if(i===rankItems.length-1)return; const a=[...rankItems];[a[i+1],a[i]]=[a[i],a[i+1]];setRankItems(a); }} disabled={i===rankItems.length-1}
                      style={{ background:"none",border:"none",cursor:i===rankItems.length-1?"not-allowed":"pointer",color:i===rankItems.length-1?D.textGray:ac,fontSize:13,padding:0,lineHeight:1 }}>▼</button>
                  </div>
                </div>
              ))}
              {!isClosed&&<button onClick={()=>{ setRankDone(true); vote(0); earn(15,"Ranked choice submitted"); }} style={{ width:"100%",padding:"12px 0",borderRadius:50,background:grad(ac,B.orange),border:"none",fontFamily:FONT,fontWeight:800,fontSize:14,color:"#fff",cursor:"pointer",marginTop:4 }}>Submit My Ranking</button>}
            </>
          ):(
            <div>
              <p style={{ fontFamily:FONT,fontWeight:700,fontSize:13,color:B.green,margin:"0 0 10px" }}>✓ Submitted! Community average ranking:</p>
              {post.options.map((opt,i)=>(
                <div key={opt} style={{ display:"flex",alignItems:"center",gap:10,marginBottom:8 }}>
                  <span style={{ fontFamily:FONT,fontWeight:800,fontSize:12,color:ac,width:22 }}>#{i+1}</span>
                  <span style={{ fontFamily:FONT,fontSize:13,color:D.text,flex:1 }}>{opt}</span>
                  <div style={{ width:80,height:6,background:D.border,borderRadius:3 }}><div style={{ height:"100%",width:`${pct(post.votes[i]||0,totalVotes)}%`,background:B.grad,borderRadius:3,transition:"width .6s ease" }}/></div>
                  <span style={{ fontFamily:FONT,fontSize:11,color:D.textMid,width:30,textAlign:"right" }}>{pct(post.votes[i]||0,totalVotes)}%</span>
                </div>
              ))}
            </div>
          )}
        </div>
      )}

      {/* ── Video Poll ── */}
      {post.type==="video"&&(
        <div style={{ position:"relative",background:"#000",minHeight:220,display:"flex",alignItems:"center",justifyContent:"center" }}>
          {post.images?.[0]?(
            <video src={post.images[0]} controls playsInline style={{ width:"100%",maxHeight:320,display:"block" }}/>
          ):(
            <div style={{ padding:"40px 20px",textAlign:"center" }}>
              <div style={{ fontSize:48,marginBottom:12 }}>🎬</div>
              <p style={{ fontFamily:FONT,fontWeight:700,fontSize:15,color:"#fff",margin:0 }}>{post.question}</p>
            </div>
          )}
          {!isClosed&&voted===null&&(
            <div style={{ position:"absolute",bottom:12,left:0,right:0,display:"flex",justifyContent:"center",gap:16 }}>
              <button onClick={e=>{e.stopPropagation();vote(1);}} aria-label="Vote No" style={{ width:56,height:56,borderRadius:"50%",background:"rgba(255,255,255,0.18)",backdropFilter:"blur(8px)",border:"2px solid rgba(255,255,255,0.4)",cursor:"pointer",fontSize:24,display:"flex",alignItems:"center",justifyContent:"center" }}>👎</button>
              <button onClick={e=>{e.stopPropagation();vote(0);}} aria-label="Vote Yes" style={{ width:56,height:56,borderRadius:"50%",background:"rgba(255,255,255,0.18)",backdropFilter:"blur(8px)",border:"2px solid rgba(255,255,255,0.4)",cursor:"pointer",fontSize:24,display:"flex",alignItems:"center",justifyContent:"center" }}>👍</button>
            </div>
          )}
          {voted!==null&&(
            <div style={{ position:"absolute",bottom:12,right:14,background:"rgba(255,255,255,0.15)",borderRadius:10,padding:"6px 12px" }}>
              <span style={{ fontFamily:FONT,fontWeight:800,fontSize:13,color:"#fff" }}>👍 {pct(lv[0]||0,totalVotes)}% · 👎 {pct(lv[1]||0,totalVotes)}%</span>
            </div>
          )}
        </div>
      )}

      {/* Social proof banner */}
      {post.trending&&voted===null&&!isClosed&&(
        <div style={{ padding:"6px 16px",background:`${B.orange}12`,display:"flex",alignItems:"center",gap:6 }}>
          <span style={{ fontSize:14 }}>🔥</span>
          <span style={{ fontFamily:FONT,fontSize:12,color:B.orange,fontWeight:700 }}>{fmt(totalVotes)} people voted — join the conversation!</span>
        </div>
      )}

      {/* Immersive */}
      <button onClick={()=>onExpand&&onExpand(post,"immersive")} style={{ width:"100%",padding:"7px 0",background:`${ac}10`,border:"none",borderTop:`1px solid ${D.border}`,cursor:"pointer",fontFamily:FONT,fontSize:12,color:ac,fontWeight:700,display:"flex",alignItems:"center",justifyContent:"center",gap:6 }}>
        ⛶ Open Immersive View
      </button>

      {/* Reactions */}
      <div style={{ padding:"8px 16px 4px",overflowX:"auto",scrollbarWidth:"none" }}>
        <ReactionBar postId={post.id} initial={post.reactions}/>
      </div>

      {/* Footer stats */}
      <div style={{ padding:"6px 16px 8px" }}>
        <div style={{ fontFamily:FONT,fontSize:13,color:ac,marginBottom:6 }}>{post.tags.join(" ")}</div>
        <div style={{ display:"flex",gap:12,alignItems:"center",flexWrap:"wrap" }}>
          <span style={{ fontFamily:FONT,fontSize:12,color:D.textMid,display:"flex",alignItems:"center",gap:4 }}><Ic.Eye/> {fmt(post.views)}</span>
          <span style={{ fontFamily:FONT,fontSize:12,color:D.textMid,display:"flex",alignItems:"center",gap:4 }}><Ic.Share/> {fmt(post.shares)}</span>
          <button onClick={()=>setShowComments(v=>!v)} style={{ background:"none",border:"none",fontFamily:FONT,fontSize:12,color:D.textMid,cursor:"pointer",padding:0,display:"flex",alignItems:"center",gap:4 }}>
            <Ic.Comment/> {comments.length>0?`${comments.length} comment${comments.length>1?"s":""}`:""} {showComments?"▲":"▼"}
          </button>
          {voted!==null&&(
            <button onClick={()=>toast("Story shared! 📸")} style={{ marginLeft:"auto",background:`${B.purple}15`,border:`1px solid ${B.purple}44`,borderRadius:50,padding:"4px 12px",fontFamily:FONT,fontSize:11,fontWeight:700,color:B.purple,cursor:"pointer" }}>📸 Share Result</button>
          )}
          {user?.accountType==="business"&&(
            <button onClick={()=>toast("Boost started! 🚀")} style={{ display:"flex",alignItems:"center",gap:4,padding:"5px 12px",borderRadius:50,background:`${ac}15`,border:`1.5px solid ${ac}44`,fontFamily:FONT,fontSize:11,fontWeight:800,color:ac,cursor:"pointer" }}><Ic.Boost/> Boost</button>
          )}
        </div>
      </div>

      {/* Comments */}
      {showComments&&(
        <div style={{ borderTop:`1px solid ${D.border}`,padding:"12px 16px 16px" }}>
          {comments.length===0&&<p style={{ textAlign:"center",color:D.textMid,fontFamily:FONT,fontSize:13,padding:"8px 0",margin:0 }}>No comments yet. Be first!</p>}
          {comments.map(c=>{const ca=USERS[c.authorId]||USERS.me; return(
            <div key={c.id} style={{ display:"flex",gap:10,marginBottom:12 }}>
              <div style={{ width:32,height:32,borderRadius:"50%",background:ca.brandColor||B.grad,display:"flex",alignItems:"center",justifyContent:"center",fontFamily:FONT,fontWeight:900,fontSize:12,color:"#fff",flexShrink:0 }}>{ca.avatar}</div>
              <div style={{ flex:1,background:D.bg,borderRadius:"0 12px 12px 12px",padding:"8px 12px" }}>
                <div style={{ fontFamily:FONT,fontWeight:800,fontSize:12,color:D.text,marginBottom:2 }}>{ca.name}</div>
                <div style={{ fontFamily:FONT,fontSize:13,color:D.text }}>{c.text}</div>
                <div style={{ fontFamily:FONT,fontSize:10,color:D.textGray,marginTop:4 }}>{c.time}</div>
              </div>
            </div>
          );})}
          <div style={{ display:"flex",gap:8,alignItems:"flex-end",marginTop:8 }}>
            <div style={{ flex:1 }}>
              <input value={commentText} onChange={e=>{if(e.target.value.length<=MAX_CHARS){setCommentText(e.target.value);setCharCount(e.target.value.length);}}} onKeyDown={e=>e.key==="Enter"&&handleComment()} placeholder="Add a comment…" maxLength={MAX_CHARS} aria-label="Write a comment"
                style={{ width:"100%",border:`1.5px solid ${D.border}`,borderRadius:50,padding:"9px 14px",fontFamily:FONT,fontSize:13,outline:"none",background:D.bg,color:D.text,boxSizing:"border-box" }}/>
              {charCount>0&&<div style={{ textAlign:"right",fontFamily:FONT,fontSize:10,color:charCount>250?B.red:D.textGray,marginTop:3 }}>{MAX_CHARS-charCount}</div>}
            </div>
            <button onClick={handleComment} aria-label="Post comment" style={{ width:36,height:36,borderRadius:"50%",background:ac,border:"none",cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0,color:"#fff" }}><Ic.Send/></button>
          </div>
        </div>
      )}
    </article>
  );
});

// ═══════════════════════════════════════════════════════════════════════════════
// FULL SCREEN  (keyboard nav, aria)
// ═══════════════════════════════════════════════════════════════════════════════
function FullScreen({ posts, startIdx, onClose, onVote }) {
  const [idx,setIdx]=useState(startIdx);
  const [anim,setAnim]=useState(null);
  const touchY=useRef(null);
  const post=posts[idx], author=USERS[post?.authorId]||USERS.me;
  const toast=useToast(); const {earn}=useXP();
  const [lv,setLv]=useState(()=>posts.map(p=>({v:[...p.votes],voted:p.userVote})));
  const cur=lv[idx], total=cur.v.reduce((a,b)=>a+(b||0),0), isClosed=post?.endsAt<=Date.now();

  const go=dir=>{const nx=idx+dir;if(nx<0||nx>=posts.length)return;setAnim(dir>0?"up":"down");setTimeout(()=>{setIdx(nx);setAnim(null);},260);};
  const vote=i=>{if(cur.voted!==null||isClosed)return;try{navigator.vibrate&&navigator.vibrate(12);}catch{}const nl=[...lv];nl[idx]={v:cur.v.map((x,j)=>j===i?x+1:x),voted:i};setLv(nl);onVote&&onVote(post.id,i,post.authorId==="me");earn(10,"Vote cast");toast("Voted! ✓");};

  useEffect(()=>{
    const h=e=>{if(e.key==="Escape")onClose();if(e.key==="ArrowDown")go(1);if(e.key==="ArrowUp")go(-1);};
    window.addEventListener("keydown",h);return()=>window.removeEventListener("keydown",h);
  },[idx]);

  return (
    <div style={{ position:"fixed",inset:0,zIndex:500,background:"#000",display:"flex",flexDirection:"column" }} role="dialog" aria-modal="true" aria-label={`Full screen: ${post?.question}`}
      onTouchStart={e=>{touchY.current=e.touches[0].clientY;}}
      onTouchEnd={e=>{if(!touchY.current)return;const d=touchY.current-e.changedTouches[0].clientY;if(Math.abs(d)>50)go(d>0?1:-1);touchY.current=null;}}>
      <div style={{ flex:1,position:"relative",overflow:"hidden",opacity:anim?0:1,transform:anim==="up"?"translateY(-30px)":anim==="down"?"translateY(30px)":"none",transition:"all .26s ease" }}>
        {post?.type==="ab"&&post.images?(
          <div style={{ display:"flex",height:"100%" }}>
            {post.images.map((img,i)=>(
              <div key={i} style={{ flex:1,position:"relative" }}>
                <button onClick={()=>vote(i)} disabled={cur.voted!==null||isClosed} style={{ width:"100%",height:"100%",border:"none",padding:0,cursor:cur.voted!==null||isClosed?"default":"pointer",background:"transparent" }}>
                  <img src={img} alt={`Option ${i+1}`} loading="lazy" style={{ width:"100%",height:"100%",objectFit:"cover",opacity:cur.voted!==null&&cur.voted!==i?0.45:1,transition:"opacity .2s" }}/>
                </button>
                {/* Fix #12: percentage on both options in full screen */}
                {cur.voted!==null&&(
                  <div style={{ position:"absolute",inset:0,display:"flex",alignItems:"center",justifyContent:"center",pointerEvents:"none" }}>
                    <div style={{ background:cur.voted===i?"rgba(255,255,255,0.95)":"rgba(0,0,0,0.5)",borderRadius:14,padding:"12px 18px",textAlign:"center" }}>
                      <div style={{ fontFamily:FONT,fontWeight:900,fontSize:28,color:cur.voted===i?B.pink:"#fff" }}>{Math.round((cur.v[i]/Math.max(total,1))*100)}%</div>
                      {cur.voted===i&&<div style={{ fontFamily:FONT,fontSize:12,color:B.textMid,marginTop:3 }}>✓ Your vote</div>}
                    </div>
                  </div>
                )}
                <div style={{ position:"absolute",bottom:90,[i===0?"left":"right"]:14,pointerEvents:"none" }}>
                  <div style={{ width:52,height:52,borderRadius:"50%",background:cur.voted===i?B.grad:"rgba(255,255,255,0.93)",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",boxShadow:"0 2px 12px rgba(0,0,0,0.3)" }}>
                    <span style={{ fontSize:9,fontWeight:900,color:cur.voted===i?"#fff":B.pink,fontFamily:FONT }}>Q</span>
                    <span style={{ fontSize:10,fontWeight:800,color:cur.voted===i?"#fff":B.navy,fontFamily:FONT }}>{cur.voted!==null?`${Math.round((cur.v[i]/Math.max(total,1))*100)}%`:fmt(cur.v[i])}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ):(
          <div style={{ width:"100%",height:"100%",background:post?.bg||B.grad,position:"relative",display:"flex",alignItems:"center",justifyContent:"center" }}>
            {post?.images?.[0]&&<img src={post.images[0]} alt={post?.question||""} loading="lazy" style={{ width:"100%",height:"100%",objectFit:"cover",position:"absolute" }}/>}
            <p style={{ position:"relative",padding:"0 32px",textAlign:"center",fontFamily:FONT,fontWeight:700,fontSize:22,color:"#fff",textShadow:"0 2px 8px rgba(0,0,0,0.4)",margin:0 }}>{post?.question}</p>
            {!isClosed&&(<>
              <button onClick={()=>vote(1)} disabled={cur.voted!==null} style={{ position:"absolute",bottom:120,left:20,width:64,height:64,borderRadius:"50%",background:B.grad,border:"none",cursor:cur.voted!==null?"default":"pointer",fontSize:28,boxShadow:"0 4px 20px rgba(0,0,0,0.4)",opacity:cur.voted!==null&&cur.voted!==1?0.4:1 }}>👎</button>
              <button onClick={()=>vote(0)} disabled={cur.voted!==null} style={{ position:"absolute",bottom:120,right:20,width:64,height:64,borderRadius:"50%",background:B.grad,border:"none",cursor:cur.voted!==null?"default":"pointer",fontSize:28,boxShadow:"0 4px 20px rgba(0,0,0,0.4)",opacity:cur.voted!==null&&cur.voted!==0?0.4:1 }}>👍</button>
            </>)}
          </div>
        )}
        <div style={{ position:"absolute",top:0,left:0,right:0,height:160,background:"linear-gradient(to bottom,rgba(0,0,0,0.72),transparent)",pointerEvents:"none",padding:"50px 16px 0" }}>
          <div style={{ display:"flex",alignItems:"center",gap:10,marginBottom:8 }}>
            <div style={{ width:36,height:36,borderRadius:"50%",background:author.brandColor||B.grad,display:"flex",alignItems:"center",justifyContent:"center",fontFamily:FONT,fontWeight:900,fontSize:14,color:"#fff" }}>{author.avatar}</div>
            <div><div style={{ fontFamily:FONT,fontWeight:800,fontSize:14,color:"#fff" }}>{author.name}</div><div style={{ fontFamily:FONT,fontSize:11,color:"rgba(255,255,255,0.8)" }}>📍 {author.location}</div></div>
            <div style={{ marginLeft:"auto" }}><Countdown endsAt={post?.endsAt||Date.now()}/></div>
          </div>
          <h2 style={{ fontFamily:FONT,fontWeight:700,fontSize:18,color:"#fff",textShadow:"0 1px 4px rgba(0,0,0,0.5)",margin:0 }}>{post?.question}</h2>
        </div>
        <div style={{ position:"absolute",bottom:64,left:16,pointerEvents:"none" }}>
          <p style={{ fontFamily:FONT,fontSize:12,color:"rgba(255,255,255,0.8)",margin:0 }}>{post?.tags?.join(" ")}</p>
        </div>
        <button onClick={onClose} aria-label="Close" style={{ position:"absolute",top:14,right:14,background:"rgba(0,0,0,0.5)",border:"none",color:"#fff",borderRadius:"50%",width:36,height:36,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center" }}><Ic.Close/></button>
        {idx>0&&<button onClick={()=>go(-1)} aria-label="Previous" style={{ position:"absolute",top:"50%",left:8,transform:"translateY(-50%)",background:"rgba(0,0,0,0.4)",border:"none",color:"#fff",borderRadius:"50%",width:34,height:34,cursor:"pointer",fontSize:14 }}>▲</button>}
        {idx<posts.length-1&&<button onClick={()=>go(1)} aria-label="Next" style={{ position:"absolute",top:"50%",right:8,transform:"translateY(-50%)",background:"rgba(0,0,0,0.4)",border:"none",color:"#fff",borderRadius:"50%",width:34,height:34,cursor:"pointer",fontSize:14 }}>▼</button>}
      </div>
      <div style={{ padding:"8px 0 24px",display:"flex",justifyContent:"center",gap:6,background:"#000" }}>
        {posts.map((_,i)=><div key={i} style={{ width:i===idx?22:6,height:6,borderRadius:3,background:i===idx?B.pink:"#444",transition:"all .2s" }}/>)}
      </div>
    </div>
  );
}

