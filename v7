              </div>
              {voted!==null&&<div style={{ position:"absolute",bottom:0,left:0,right:0,height:4,pointerEvents:"none" }}><div style={{ height:"100%",width:`${pct(lv[i]||0,totalVotes)}%`,background:voted===i?ac:"rgba(255,255,255,0.4)",transition:"width .7s ease" }}/></div>}
            </div>
          ))}
        </div>
      )}

      {/* ── 4-Image Grid ── */}
      {post.type==="image4"&&post.images&&(
        <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:2,position:"relative" }}>
          <ClosedOverlay/>
          {post.images.slice(0,4).map((img,i)=>(
            <div key={i} style={{ position:"relative",overflow:"hidden" }}>
              <button onClick={()=>vote(i)} disabled={voted!==null||isClosed}
                style={{ width:"100%",border:"none",padding:0,cursor:voted!==null||isClosed?"default":"pointer",background:"transparent",display:"block" }}>
                <img src={img} alt={`Option ${String.fromCharCode(65+i)}`} loading="lazy"
                  style={{ width:"100%",height:160,objectFit:"cover",display:"block",transition:"opacity .25s",opacity:voted!==null&&voted!==i?0.5:1 }}/>
