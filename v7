// XP BADGE — shown in top bar
// ═══════════════════════════════════════════════════════════════════════════════
function XPBadge({ onClick }) {
  const { xp, level } = useXP();
  const { nextLevel, progress } = useMemo(() => {
    const next = LEVELS.find(l=>l.min>xp) || LEVELS[LEVELS.length-1];
    const prog = next.min===Infinity ? 100 : pct(xp-level.min, next.min-level.min);
    return { nextLevel:next, progress:prog };
  }, [xp, level]);
  return (
    <button onClick={onClick} aria-label={`Level: ${level.label}, ${xp} XP`}
      style={{ display:"flex",alignItems:"center",gap:6,background:"none",border:`1.5px solid ${level.color}44`,borderRadius:50,padding:"5px 11px",cursor:"pointer" }}>
      <span style={{ fontSize:14 }}>{level.icon}</span>
      <div>
        <div style={{ fontFamily:FONT,fontWeight:800,fontSize:10,color:level.color,lineHeight:1 }}>{level.label}</div>
        <div style={{ width:44,height:3,background:B.light,borderRadius:2,marginTop:2 }}>
          <div style={{ height:"100%",width:`${progress}%`,background:level.color,borderRadius:2,transition:"width .5s" }}/>
        </div>
      </div>
    </button>
  );
}

