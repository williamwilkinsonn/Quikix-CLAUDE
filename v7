let _sid=0;
function Sparkline({ data, color=B.pink, height=40 }) {
  const gid = useRef(`sp-${++_sid}`).current;
  const { path, fill } = useMemo(() => {
    const w=200,h=height,mx=Math.max(...data,1),mn=Math.min(...data,0);
    const pts=data.map((v,i)=>({x:(i/(data.length-1))*w,y:h-((v-mn)/(mx-mn||1))*(h-4)-2}));
    const p="M"+pts.map(pt=>`${pt.x.toFixed(1)},${pt.y.toFixed(1)}`).join("L");
    return { path:p, fill:`${p}L${w},${h}L0,${h}Z` };
  }, [data,height]);
  return (
    <svg width="100%" height={height} viewBox={`0 0 200 ${height}`} preserveAspectRatio="none" aria-hidden="true">
      <defs><linearGradient id={gid} x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stopColor={color} stopOpacity="0.3"/><stop offset="100%" stopColor={color} stopOpacity="0"/></linearGradient></defs>
      <path d={fill} fill={`url(#${gid})`}/><path d={path} fill="none" stroke={color} strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"/>
    </svg>
  );
}
function BarChart({ data, height=80 }) {
  const max = useMemo(()=>Math.max(...data.map(d=>d.value),1),[data]);
  const { D } = useTheme();
  return (
    <div style={{ display:"flex", alignItems:"flex-end", gap:5, height }} role="img" aria-label={data.map(d=>`${d.label}: ${d.value}`).join(", ")}>
      {data.map((d,i)=>{
        const pk=d.value===max;
        return (
          <div key={i} style={{ flex:1, display:"flex", flexDirection:"column", alignItems:"center", gap:4 }}>
            <div style={{ width:"100%", height:Math.max(4,(d.value/max)*(height-20)), background:pk?B.grad:`${B.pink}30`, borderRadius:"5px 5px 0 0", transition:"height .5s ease", position:"relative" }}>
              {pk && <div style={{ position:"absolute", top:-17, left:"50%", transform:"translateX(-50%)", fontFamily:FONT, fontSize:8, fontWeight:900, color:B.pink, whiteSpace:"nowrap" }}>PEAK</div>}
            </div>
            <span style={{ fontFamily:FONT, fontSize:9, color:D.textMid, fontWeight:600 }}>{d.label}</span>
          </div>
        );
      })}
    </div>
  );
}
function DonutChart({ data, size=120 }) {
  const r=42,cx=60,cy=60,circ=2*Math.PI*r,total=data.reduce((a,d)=>a+d.value,0);
  let offset=0;
  return (
    <div style={{ position:"relative", width:size, height:size }} role="img" aria-label={data.map(d=>`${d.label} ${d.value}%`).join(", ")}>
      <svg width={size} height={size} viewBox="0 0 120 120" aria-hidden="true">
        {data.map((d,i)=>{const dash=(d.value/total)*circ;const el=<circle key={i} cx={cx} cy={cy} r={r} fill="none" stroke={d.color} strokeWidth="16" strokeDasharray={`${dash} ${circ-dash}`} strokeDashoffset={-offset} transform="rotate(-90 60 60)"/>;offset+=dash;return el;})}
        <circle cx={cx} cy={cy} r={34} fill="white"/>
      </svg>
      <div style={{ position:"absolute", inset:0, display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center" }}>
        <span style={{ fontFamily:FONT, fontWeight:900, fontSize:20, color:B.navy }}>{data[0]?.value}%</span>
        <span style={{ fontFamily:FONT, fontSize:9, color:B.textMid, fontWeight:700 }}>{data[0]?.label}</span>
      </div>
    </div>
  );
}
let _rid=0;
function ScoreRing({ score, label, size=110 }) {
  const gid=useRef(`sr-${++_rid}`).current;
  const r=44,circ=2*Math.PI*r,dash=(score/100)*circ;
  return (
    <div style={{ position:"relative", width:size, height:size }} role="img" aria-label={`Score ${score}/100 ${label}`}>
      <svg width={size} height={size} viewBox="0 0 110 110" aria-hidden="true">
        <circle cx="55" cy="55" r={r} fill="none" stroke={B.light} strokeWidth="10"/>
        <defs><linearGradient id={gid} x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stopColor={B.pink}/><stop offset="100%" stopColor={B.orange}/></linearGradient></defs>
        <circle cx="55" cy="55" r={r} fill="none" stroke={`url(#${gid})`} strokeWidth="10" strokeDasharray={`${dash} ${circ-dash}`} strokeDashoffset={circ*0.25} strokeLinecap="round"/>
      </svg>
      <div style={{ position:"absolute", inset:0, display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center" }}>
        <span style={{ fontFamily:FONT, fontWeight:900, fontSize:24, color:B.navy, lineHeight:1 }}>{score}</span>
        <span style={{ fontFamily:FONT, fontSize:10, fontWeight:700, color:B.textMid }}>{label}</span>
      </div>
    </div>
  );
}

