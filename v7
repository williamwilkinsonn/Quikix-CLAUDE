// Fix #21: Tick context so only Countdown re-renders each second, not parents
const TickCtx = createContext(0);
function TickProvider({ children }) {
  const [tick, setTick] = useState(0);
  useEffect(() => { const id = setInterval(() => setTick(t=>t+1), 1000); return ()=>clearInterval(id); }, []);
  return <TickCtx.Provider value={tick}>{children}</TickCtx.Provider>;
}

// Fix #17: Toast context
const ToastCtx = createContext(null);
function ToastProvider({ children }) {
  const [toasts, setToasts] = useState([]);
  const show = useCallback((msg, type="success") => {
    const id = uid();
    setToasts(ts=>[...ts,{id,msg,type}]);
    setTimeout(()=>setToasts(ts=>ts.filter(t=>t.id!==id)), 2800);
  },[]);
  return (
    <ToastCtx.Provider value={show}>
      {children}
      <div style={{ position:"fixed",bottom:96,left:"50%",transform:"translateX(-50%)",zIndex:9999,display:"flex",flexDirection:"column",gap:8,alignItems:"center",pointerEvents:"none",width:"100%",maxWidth:400,padding:"0 20px" }}>
        {toasts.map(t=>(
          <div key={t.id} style={{ background:t.type==="xp"?B.gradG:t.type==="error"?B.red:B.navy,color:"#fff",padding:"11px 22px",borderRadius:50,fontFamily:FONT,fontWeight:700,fontSize:14,boxShadow:B.shadowMd,animation:"toastIn .25s ease",whiteSpace:"nowrap" }}>
            {t.type==="xp"?"⭐ ":t.type==="success"?"✓ ":t.type==="error"?"✕ ":"ℹ "}{t.msg}
          </div>
        ))}
      </div>
    </ToastCtx.Provider>
  );
}
const useToast = () => useContext(ToastCtx);

// ─── XP Context ───────────────────────────────────────────────────────────────
const XPCtx = createContext(null);
function XPProvider({ children }) {
  const [xp, setXp]     = useState(getXP);
  const [burst, setBurst] = useState(null);
  const toast = useContext(ToastCtx);
  const earn = useCallback((amount, reason) => {
    setXp(prev => { const next=prev+amount; saveXP(next); return next; });
    setBurst(reason);
    setTimeout(()=>setBurst(null), 1600);
    if(toast) toast(`+${amount} XP — ${reason}`, "xp");
  }, [toast]);
  const level = useMemo(()=>getLevel(xp),[xp]);
  return (
    <XPCtx.Provider value={{ xp, earn, level }}>
      {children}
      {burst&&(
        <div style={{ position:"fixed",top:"18%",left:"50%",transform:"translateX(-50%)",zIndex:9998,background:B.gradG,color:"#fff",padding:"12px 28px",borderRadius:50,fontFamily:FONT,fontWeight:900,fontSize:15,boxShadow:B.shadowHeavy,animation:"xpBurst .5s ease",pointerEvents:"none",whiteSpace:"nowrap" }}>
          ⭐ {burst}
        </div>
      )}
    </XPCtx.Provider>
  );
}
const useXP = () => useContext(XPCtx);

// Fix #28: Dark mode context
const ThemeCtx = createContext("light");
function ThemeProvider({ children }) {
  const [mode, setMode] = useState(() => {
    try { return localStorage.getItem("qx_theme") || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"); }
    catch { return "light"; }
  });
  const toggle = () => setMode(m => { const n = m==="dark"?"light":"dark"; try{localStorage.setItem("qx_theme",n);}catch{} return n; });
  const D = mode==="dark" ? {
    bg:"#0D0F1A", surface:"#161825", card:"#1E2035", border:"#2A2D45",
    text:"#F0F2FF", textMid:"#A0A3C0", textGray:"#6B6E88",
  } : {
    bg:B.offWhite, surface:B.white, card:B.white, border:B.border,
    text:B.navy, textMid:B.textMid, textGray:B.textGray,
  };
  return <ThemeCtx.Provider value={{ mode, toggle, D }}>{children}</ThemeCtx.Provider>;
}
const useTheme = () => useContext(ThemeCtx);

