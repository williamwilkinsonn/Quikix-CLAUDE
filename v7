// ═══════════════════════════════════════════════════════════════════════════════
// COUNTDOWN  (Fix #21: reads from context, doesn't create interval)
// ═══════════════════════════════════════════════════════════════════════════════
function Countdown({ endsAt }) {
  const tick = useContext(TickCtx);
  const { D } = useTheme();
  const t = useMemo(() => {
    const d = Math.max(0, endsAt - Date.now());
    return { d:Math.floor(d/86400000), h:Math.floor((d%86400000)/3600000), m:Math.floor((d%3600000)/60000), s:Math.floor((d%60000)/1000) };
  }, [tick, endsAt]);
  const live = endsAt > Date.now();
  if (!live) return <span style={{ fontFamily:FONT, fontSize:11, fontWeight:800, color:D.textMid, background:D.border, padding:"3px 8px", borderRadius:50 }}>CLOSED</span>;
  return (
    <div style={{ display:"flex", alignItems:"center", gap:5 }} aria-label={`Closes in ${pad(t.d)}:${pad(t.h)}:${pad(t.m)}:${pad(t.s)}`}>
      <span style={{ fontFamily:FONT, fontWeight:700, fontSize:12, color:t.h<1&&t.d<1?B.red:D.text, letterSpacing:0.5, fontVariantNumeric:"tabular-nums" }}>{pad(t.d)}:{pad(t.h)}:{pad(t.m)}:{pad(t.s)}</span>
      <div style={{ width:13, height:13, borderRadius:"50%", border:`2px solid ${B.green}`, display:"flex", alignItems:"center", justifyContent:"center" }} aria-hidden="true">
        <div style={{ width:5, height:5, borderRadius:"50%", background:B.green, animation:"pulseDot 2s infinite" }}/>
      </div>
    </div>
  );
}

