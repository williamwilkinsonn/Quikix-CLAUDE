          <div>
            <div style={{ background:B.gradB,borderRadius:20,padding:"20px 18px",marginBottom:16 }}>
              <h3 style={{ fontFamily:FONT,fontWeight:900,fontSize:16,color:"#fff",marginBottom:8,marginTop:0 }}>📊 vs Industry Benchmarks</h3>
              <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:10 }}>
                {[["Industry Avg ER","4.2%"],["Your ER","7.8%"],["Avg Completion","68%"],["Your Completion","84%"]].map(([l,v],i)=>(
                  <div key={l} style={{ background:"rgba(255,255,255,0.1)",borderRadius:12,padding:"10px 12px" }}>
                    <div style={{ fontFamily:FONT,fontSize:10,color:"rgba(255,255,255,0.6)",marginBottom:2 }}>{l}</div>
                    <div style={{ fontFamily:FONT,fontWeight:900,fontSize:20,color:i%2===1?"#00FF87":"rgba(255,255,255,0.65)" }}>{v}</div>
                  </div>
                ))}
              </div>
            </div>
            {d.insights.map((ins,i)=>(
              <div key={i} style={{ background:D.card,borderRadius:16,padding:"14px 16px",border:`1.5px solid ${ins.color}28`,boxShadow:B.shadow,marginBottom:12,borderLeft:`4px solid ${ins.color}` }}>
                <div style={{ display:"flex",alignItems:"flex-start",gap:12 }}>
                  <div style={{ width:38,height:38,borderRadius:10,background:`${ins.color}18`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:20,flexShrink:0 }}>{ins.icon}</div>
                  <div style={{ flex:1 }}><h4 style={{ fontFamily:FONT,fontWeight:800,fontSize:14,color:D.text,marginBottom:4,marginTop:0 }}>{ins.title}</h4><p style={{ fontFamily:FONT,fontSize:13,color:D.textMid,lineHeight:1.5,margin:0 }}>{ins.body}</p></div>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  );
}

// ═══════════════════════════════════════════════════════════════════════════════
// MAIN APP
// ═══════════════════════════════════════════════════════════════════════════════
function AppInner() {
  const { D, mode } = useTheme();
  const toast = useToast();
  const [screen,setScreen]=useState("splash");
  const [authType,setAuthType]=useState(null);
  const [user,setUser]=useState(USERS.me);
  const [tab,setTab]=useState("feed");
  const [feedTab,setFeedTab]=useState("foryou");
  const [posts,setPosts]=useState(INIT_POSTS);
  const [isFirstOpen,setIsFirstOpen]=useState(getFirstOpen); // Fix #4: persisted
  const [isLoading,setIsLoading]=useState(true);             // Fix #3: actually used
  const [isRefreshing,setIsRefreshing]=useState(false);
  const [fullIdx,setFullIdx]=useState(null);
  const [showFormat,setShowFormat]=useState(false);
  const [createFmt,setCreateFmt]=useState(null);
  const [sharePost,setSharePost]=useState(null);
  const [notifs,setNotifs]=useState(INITIAL_NOTIFS); // Fix #1: static, not inside component
  const [search,setSearch]=useState("");
  const [searchCat,setSearchCat]=useState("All");
  const [savedIds,setSavedIds]=useState([]);
  const [remindIds,setRemindIds]=useState([]);
  const touchStartY=useRef(null);
  const feedRef=useRef(null);
  const postsRef=useRef(posts); // Fix #6: stable ref
  useEffect(()=>{ postsRef.current=posts; },[posts]);

  // Fix #3: actually trigger loading
  useEffect(()=>{ const t=setTimeout(()=>setIsLoading(false),1200); return()=>clearTimeout(t); },[]);

  const unread    = useMemo(()=>notifs.filter(n=>n.unread).length,[notifs]);
  const msgUnread = useMemo(()=>notifs.filter(n=>n.type==="comment"&&n.unread).length,[notifs]);

  // Fix #2: only notify if it's the user's own post being voted on
  const handleVote=useCallback((id,i,isMyPost)=>{
    setPosts(ps=>ps.map(p=>p.id===id?{...p,votes:p.votes.map((v,j)=>j===i?v+1:v),userVote:i}:p));
    if(isMyPost){
      setNotifs(ns=>[{id:uid(),icon:"👍",title:"Someone voted on your poll!",body:"Results are updating in real-time",time:"Just now",unread:true,type:"vote"},...ns]);
    }
  },[]);

  // Fix #6: stable handleExpand using ref
  const handleExpand=useCallback((p,viewMode="immersive")=>{
    const i=postsRef.current.findIndex(x=>x.id===p.id);
    setFullIdx(i>=0?i:0);
  },[]);

  const handlePublish=useCallback((p)=>{
    setPosts(ps=>[p,...ps]);
    setCreateFmt(null);
    setTab("feed");
    if(isFirstOpen){ setIsFirstOpen(false); markFirstOpen(); } // Fix #4
    setNotifs(ns=>[{id:uid(),icon:"🎉",title:"Poll published!",body:`"${p.question.slice(0,40)}…"`,time:"Just now",unread:true,type:"milestone"},...ns]);
    toast("Poll is live! 🎉");
  },[isFirstOpen]);

  const handleEditBrand=useCallback((color)=>setUser(u=>({...u,brandColor:color})),[]);
  const handleSave=useCallback((id)=>setSavedIds(ids=>ids.includes(id)?ids.filter(x=>x!==id):[...ids,id]),[]);
  const handleRemind=useCallback((id)=>setRemindIds(ids=>ids.includes(id)?ids.filter(x=>x!==id):[...ids,id]),[]);

  // Pull to refresh
  const onTouchStart=e=>{ touchStartY.current=e.touches[0].clientY; };
  const onTouchEnd=e=>{
    if(!touchStartY.current||feedRef.current?.scrollTop>0)return;
    const diff=e.changedTouches[0].clientY-touchStartY.current;
    if(diff>80&&!isRefreshing){ setIsRefreshing(true); setTimeout(()=>{ setIsRefreshing(false); toast("Feed refreshed ✓"); },1400); }
    touchStartY.current=null;
  };

  // Fix #9: distinct Following content
  const followingIds=useMemo(()=>Object.keys(USERS).filter(id=>id!=="me"),[]);
  const feedPosts=useMemo(()=>{
    if(feedTab==="following") return posts.filter(p=>followingIds.includes(p.authorId));
    if(feedTab==="trending")  return [...posts].sort((a,b)=>b.votes.reduce((x,y)=>x+y,0)-a.votes.reduce((x,y)=>x+y,0));
    return posts;
  },[feedTab,posts,followingIds]);

  const filteredPosts=useMemo(()=>posts.filter(p=>{
    const q=!search||p.question.toLowerCase().includes(search.toLowerCase())||p.tags.some(t=>t.includes(search.toLowerCase()));
    const c=searchCat==="All"||p.tags.some(t=>t.toLowerCase().includes(searchCat.toLowerCase()));
    return q&&c;
  }),[posts,search,searchCat]);

  if(screen==="splash") return <Splash onDone={type=>{if(type==="guest")setScreen("app");else{setAuthType(type);setScreen("auth");}}}/>;
  if(screen==="auth")   return <Onboarding type={authType} onDone={u=>{setUser(prev=>({...prev,...u}));setScreen("app");}}/>;

  // Fix #24: Messages moved into bottom nav, replacing the less-used top-bar position
  const navItems=[
    {id:"feed",     NavIcon:Ic.Home,   label:"Feed"   },
    {id:"search",   NavIcon:Ic.Search, label:"Search" },
    {id:"create",   NavIcon:null,      label:"Create" },
    {id:"gamify",   NavIcon:Ic.Trophy, label:"Levels" },
    {id:"profile",  NavIcon:Ic.User,   label:"Profile"},
  ];

  return (
    <div style={{ background:D.bg,minHeight:"100vh",maxWidth:480,margin:"0 auto",position:"relative",fontFamily:FONT }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');
        *{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
        ::-webkit-scrollbar{width:0;}
        input,textarea,button{font-family:'Nunito',sans-serif;}
        input::placeholder,textarea::placeholder{color:#aaa;}
        @keyframes pulseDot{0%,100%{opacity:1;}50%{opacity:0.3;}}
        @keyframes shimmer{0%{background-position:-400% 0;}100%{background-position:400% 0;}}
        @keyframes trendPulse{0%,100%{box-shadow:0 0 0 0 rgba(232,64,122,0.4);}50%{box-shadow:0 0 0 8px rgba(232,64,122,0);}}
        @keyframes toastIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
        @keyframes xpBurst{0%{opacity:0;transform:translateX(-50%) scale(0.7);}40%{opacity:1;transform:translateX(-50%) scale(1.08);}70%{transform:translateX(-50%) scale(0.97);}100%{opacity:1;transform:translateX(-50%) scale(1);}}
      `}</style>

      {/* TOP BAR — XPBadge + Messages + Notifications + Analytics */}
      <header style={{ position:"sticky",top:0,zIndex:100,background:D.card,borderBottom:`1px solid ${D.border}`,padding:"10px 14px",display:"flex",alignItems:"center",justifyContent:"space-between" }}>
        <Logo size={28}/>
        <div style={{ display:"flex",alignItems:"center",gap:8 }}>
          <XPBadge onClick={()=>setTab("gamify")}/>
          <button onClick={()=>setTab("analytics")} aria-label="Analytics" style={{ background:"none",border:"none",cursor:"pointer",color:tab==="analytics"?user.brandColor||B.pink:D.textGray,padding:4 }}><Ic.Chart/></button>
          <button onClick={()=>setTab("messages")} aria-label={`Messages${msgUnread>0?`, ${msgUnread} unread`:""}`} style={{ background:"none",border:"none",cursor:"pointer",color:tab==="messages"?user.brandColor||B.pink:D.textGray,padding:4,position:"relative" }}>
            <Ic.Msg/>
            {msgUnread>0&&<div style={{ position:"absolute",top:0,right:0,width:16,height:16,background:B.pink,borderRadius:"50%",display:"flex",alignItems:"center",justifyContent:"center",border:`2px solid ${D.card}` }}><span style={{ fontFamily:FONT,fontWeight:900,fontSize:8,color:"#fff" }}>{msgUnread}</span></div>}
          </button>
          <button onClick={()=>setTab("notifs")} aria-label={`Notifications, ${unread} unread`} style={{ background:"none",border:"none",cursor:"pointer",position:"relative",padding:4,color:tab==="notifs"?user.brandColor||B.pink:D.textGray }}>
            <Ic.Bell/>
            {unread>0&&<div style={{ position:"absolute",top:0,right:0,width:17,height:17,background:B.pink,borderRadius:"50%",display:"flex",alignItems:"center",justifyContent:"center",border:`2px solid ${D.card}` }}><span style={{ fontFamily:FONT,fontWeight:900,fontSize:9,color:"#fff" }}>{unread}</span></div>}
          </button>
          <button onClick={()=>setTab("profile")} aria-label={`${user.name}'s profile`} style={{ width:34,height:34,borderRadius:"50%",background:user.brandColor||B.grad,display:"flex",alignItems:"center",justifyContent:"center",fontFamily:FONT,fontWeight:900,fontSize:14,color:"#fff",border:`2px solid ${D.card}`,boxShadow:B.shadow,cursor:"pointer",flexShrink:0 }}>
            {user.avatar||user.name?.[0]||"?"}
          </button>
        </div>
      </header>

      <main style={{ paddingBottom:88 }} ref={feedRef} onTouchStart={onTouchStart} onTouchEnd={onTouchEnd}>
        {isRefreshing&&<div style={{ textAlign:"center",padding:"12px 0",background:D.card,borderBottom:`1px solid ${D.border}` }}><span style={{ fontFamily:FONT,fontSize:13,color:user.brandColor||B.pink,fontWeight:700 }}>↻ Refreshing…</span></div>}

        {tab==="feed"&&(
          <div>
            <nav style={{ background:D.card,borderBottom:`1px solid ${D.border}`,display:"flex",padding:"0 16px" }}>
              {[["foryou","For You"],["following","Following"],["trending","🔥 Trending"]].map(([id,label])=>(
                <button key={id} onClick={()=>setFeedTab(id)} role="tab" aria-selected={feedTab===id} style={{ padding:"12px 16px",border:"none",borderBottom:`2.5px solid ${feedTab===id?user.brandColor||B.pink:"transparent"}`,background:"transparent",fontFamily:FONT,fontWeight:feedTab===id?800:600,fontSize:13,color:feedTab===id?user.brandColor||B.pink:D.textMid,cursor:"pointer",whiteSpace:"nowrap" }}>{label}</button>
              ))}
            </nav>

            {/* Stories — Fix #22: uses live posts state */}
            <div style={{ background:D.card,borderBottom:`1px solid ${D.border}`,padding:"12px 16px" }}>
              <div style={{ display:"flex",gap:14,overflowX:"auto",scrollbarWidth:"none" }}>
                {[{authorId:"me",label:"Your Poll",isMe:true},...posts.slice(0,5).map(p=>({authorId:p.authorId,label:USERS[p.authorId]?.name?.split(" ")[0]||"User"}))].map((s,i)=>{
                  const a=USERS[s.authorId]||USERS.me;
                  return (
                    <button key={i} onClick={s.isMe?()=>setShowFormat(true):()=>handleExpand(posts.find(p=>p.authorId===s.authorId)||posts[0])} style={{ display:"flex",flexDirection:"column",alignItems:"center",gap:5,flexShrink:0,cursor:"pointer",background:"none",border:"none",padding:0 }}>
                      <div style={{ width:52,height:52,borderRadius:"50%",background:s.isMe?D.surface:a.brandColor||B.grad,display:"flex",alignItems:"center",justifyContent:"center",fontFamily:FONT,fontWeight:900,fontSize:s.isMe?24:17,color:s.isMe?user.brandColor||B.pink:"#fff",border:`2.5px solid ${s.isMe?user.brandColor||B.pink:a.brandColor||B.orange}`,boxShadow:B.shadow }}>{s.isMe?"+":a.avatar}</div>
                      <span style={{ fontFamily:FONT,fontSize:10,fontWeight:600,color:D.textMid,maxWidth:52,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap" }}>{s.label}</span>
                    </button>
                  );
                })}
              </div>
            </div>

            {/* Fix #3: isLoading now properly wired, Fix #7/9: Welcome & Following empty states */}
            {isLoading ? (
              <div aria-busy="true">{[1,2,3].map(i=><PostSkeleton key={i}/>)}</div>
            ) : isFirstOpen&&feedTab==="foryou" ? (
              <WelcomeScreen user={user} onStart={()=>{setIsFirstOpen(false);markFirstOpen();}}/>
            ) : feedTab==="following"&&feedPosts.length===0 ? (
              <div style={{ textAlign:"center",padding:"60px 24px" }}>
                <div style={{ fontSize:48,marginBottom:16 }}>👥</div>
                <h3 style={{ fontFamily:FONT,fontWeight:800,fontSize:18,color:D.text,marginBottom:8,marginTop:0 }}>Follow more creators</h3>
                <p style={{ fontFamily:FONT,fontSize:14,color:D.textMid,marginBottom:20,marginTop:0 }}>Tap Follow on accounts you like to see their polls here</p>
                <button onClick={()=>setTab("search")} style={{ padding:"12px 28px",borderRadius:50,background:user.brandColor?grad(user.brandColor,B.orange):B.grad,border:"none",fontFamily:FONT,fontWeight:800,fontSize:14,color:"#fff",cursor:"pointer" }}>Discover People →</button>
              </div>
            ) : (
              feedPosts.map(p=><PostCard key={p.id} post={p} user={user} onVote={handleVote} onExpand={handleExpand} onShare={setSharePost} onSave={handleSave} onRemind={handleRemind} savedIds={savedIds} remindIds={remindIds}/>)
            )}
          </div>
        )}

        {tab==="search"&&(
          <div>
            <div style={{ padding:"14px 16px",position:"sticky",top:56,background:D.card,zIndex:9,borderBottom:`1px solid ${D.border}` }}>
              <div style={{ position:"relative",marginBottom:10 }}>
                <span style={{ position:"absolute",left:14,top:"50%",transform:"translateY(-50%)",color:D.textGray }}><Ic.Search/></span>
                <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="Search polls, brands, tags…" style={{ width:"100%",padding:"11px 14px 11px 44px",border:`1.5px solid ${D.border}`,borderRadius:50,fontFamily:FONT,fontSize:14,color:D.text,outline:"none",background:D.surface,boxSizing:"border-box" }}/>
              </div>
              <div style={{ display:"flex",gap:8,overflowX:"auto",scrollbarWidth:"none" }}>
                {SEARCH_CATS.map(c=><button key={c} onClick={()=>setSearchCat(c)} style={{ flexShrink:0,padding:"7px 16px",borderRadius:50,border:`1.5px solid ${searchCat===c?user.brandColor||B.pink:D.border}`,background:searchCat===c?`${user.brandColor||B.pink}15`:D.card,fontFamily:FONT,fontWeight:700,fontSize:12,color:searchCat===c?user.brandColor||B.pink:D.textMid,cursor:"pointer" }}>{c}</button>)}
              </div>
            </div>
            {!search&&searchCat==="All"&&(
              <section style={{ padding:"16px" }}>
                <h2 style={{ fontFamily:FONT,fontWeight:800,fontSize:16,color:D.text,marginBottom:14,marginTop:0 }}>🔥 Trending Now</h2>
                {ANALYTICS.hashtags.map((h,i)=>(
                  <button key={h.tag} onClick={()=>setSearch(h.tag)} style={{ display:"flex",alignItems:"center",padding:"13px 0",background:"none",border:"none",borderBottom:`1px solid ${D.border}`,cursor:"pointer",textAlign:"left",width:"100%" }}>
                    <div style={{ width:34,height:34,borderRadius:10,background:`${user.brandColor||B.pink}18`,display:"flex",alignItems:"center",justifyContent:"center",fontFamily:FONT,fontWeight:900,fontSize:12,color:user.brandColor||B.pink,marginRight:14,flexShrink:0 }}>#{i+1}</div>
                    <div style={{ flex:1 }}>
                      <div style={{ fontFamily:FONT,fontWeight:800,fontSize:15,color:D.text }}>{h.tag}</div>
                      <div style={{ fontFamily:FONT,fontSize:12,color:D.textMid }}>{fmt(h.votes)} votes · <span style={{ color:B.green }}>{h.growth}</span></div>
                    </div>
                    <span style={{ fontSize:18,color:D.textGray }}>›</span>
                  </button>
                ))}
                <h2 style={{ fontFamily:FONT,fontWeight:800,fontSize:16,color:D.text,margin:"24px 0 14px" }}>👥 Suggested Accounts</h2>
                {SUGGESTED.map(u=>(
                  <div key={u.id} style={{ display:"flex",alignItems:"center",gap:12,padding:"12px 0",borderBottom:`1px solid ${D.border}` }}>
                    <div style={{ width:44,height:44,borderRadius:"50%",background:u.brandColor,display:"flex",alignItems:"center",justifyContent:"center",fontFamily:FONT,fontWeight:900,fontSize:16,color:"#fff",flexShrink:0 }}>{u.avatar}</div>
                    <div style={{ flex:1 }}><div style={{ fontFamily:FONT,fontWeight:800,fontSize:14,color:D.text }}>{u.name} {u.verified&&<span style={{ color:u.brandColor,fontSize:12 }}>✓</span>}</div><div style={{ fontFamily:FONT,fontSize:12,color:D.textMid }}>{fmt(u.followers)} followers</div></div>
                    <button onClick={()=>toast(`Following ${u.name}! 👋`)} style={{ padding:"8px 18px",borderRadius:50,background:u.brandColor,border:"none",fontFamily:FONT,fontWeight:800,fontSize:12,color:"#fff",cursor:"pointer" }}>Follow</button>
                  </div>
                ))}
              </section>
            )}
            {(search||searchCat!=="All")&&(
              <div>
                {filteredPosts.length===0&&<div style={{ textAlign:"center",padding:"50px 20px" }}><p style={{ fontFamily:FONT,color:D.textMid }}>No results for "{search}"</p></div>}
                {filteredPosts.map(p=>{
                  const a=USERS[p.authorId]||USERS.me;
                  return (
                    <div key={p.id} onClick={()=>handleExpand(p)} style={{ display:"flex",gap:12,padding:"14px 16px",borderBottom:`1px solid ${D.border}`,cursor:"pointer",background:D.card }} role="button" tabIndex={0}>
                      {/* Fix #27: colored bg for text posts in search */}
                      <div style={{ width:58,height:58,borderRadius:12,overflow:"hidden",flexShrink:0,background:p.bg||D.surface,display:"flex",alignItems:"center",justifyContent:"center" }}>
                        {p.images?.[0]?<img src={p.images[0]} alt="" loading="lazy" style={{ width:"100%",height:"100%",objectFit:"cover" }}/>:<span style={{ fontFamily:FONT,fontSize:9,fontWeight:700,color:p.textColor||D.textMid,textAlign:"center",padding:4 }}>{p.question.slice(0,20)}…</span>}
                      </div>
                      <div style={{ flex:1,minWidth:0 }}>
                        <div style={{ fontFamily:FONT,fontWeight:700,fontSize:14,color:D.text,marginBottom:4,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap" }}>{p.question}</div>
                        <div style={{ fontFamily:FONT,fontSize:12,color:a.brandColor||B.pink,marginBottom:2 }}>{a.name} {a.verified&&"✓"}</div>
                        <div style={{ fontFamily:FONT,fontSize:12,color:D.textMid }}>{fmt(p.votes.reduce((a,b)=>a+(b||0),0))} votes · {fmt(p.views)} views</div>
                      </div>
                    </div>
                  );
                })}
              </div>
            )}
          </div>
        )}

        {tab==="analytics"&&<div style={{ padding:"16px 16px 0" }}><h1 style={{ fontFamily:FONT,fontWeight:900,fontSize:20,color:D.text,marginBottom:16,marginTop:0 }}>Analytics</h1><AnalyticsPage user={user} posts={posts}/></div>}
        {tab==="messages"&&<MessagesPage/>}
        {tab==="gamify"&&<GamificationPage/>}
        {tab==="business"&&user.accountType==="business"&&<BusinessDashboard user={user}/>}
        {tab==="notifs"&&(
          <div>
            <div style={{ padding:"16px 18px 10px",display:"flex",alignItems:"center",justifyContent:"space-between" }}>
              <h1 style={{ fontFamily:FONT,fontWeight:900,fontSize:20,color:D.text,margin:0 }}>Activity</h1>
              <button onClick={()=>setNotifs(ns=>ns.map(n=>({...n,unread:false})))} style={{ background:"none",border:"none",fontFamily:FONT,fontSize:13,color:user.brandColor||B.pink,fontWeight:700,cursor:"pointer" }}>Mark all read</button>
            </div>
            {notifs.map(n=>(
              <div key={n.id} style={{ display:"flex",gap:13,padding:"14px 18px",borderBottom:`1px solid ${D.border}`,background:n.unread?`${B.pink}08`:D.card }}>
                <div style={{ width:44,height:44,borderRadius:"50%",background:user.brandColor?grad(user.brandColor,B.orange):B.grad,display:"flex",alignItems:"center",justifyContent:"center",fontSize:19,flexShrink:0 }}>{n.icon}</div>
                <div style={{ flex:1 }}>
                  <div style={{ fontFamily:FONT,fontWeight:700,fontSize:14,color:D.text }}>{n.title}</div>
                  {n.body&&<div style={{ fontFamily:FONT,fontSize:13,color:D.textMid,marginTop:2 }}>{n.body}</div>}
                  {/* Fix #26: timestamps use textMid not midGray */}
                  <div style={{ fontFamily:FONT,fontSize:11,color:D.textMid,marginTop:4 }}>{n.time}</div>
                </div>
                {n.unread&&<div style={{ width:9,height:9,borderRadius:"50%",background:user.brandColor||B.pink,flexShrink:0,marginTop:6 }}/>}
              </div>
            ))}
          </div>
        )}
        {tab==="profile"&&<ProfilePage user={user} posts={posts} onEditBrand={handleEditBrand} onNavigate={setTab}/>}
      </main>

      {/* BOTTOM NAV — Fix #24: Messages in nav, not top bar */}
      <nav style={{ position:"fixed",bottom:0,left:"50%",transform:"translateX(-50%)",width:"100%",maxWidth:480,background:D.card,borderTop:`1px solid ${D.border}`,display:"flex",padding:"8px 0 22px",zIndex:200 }}>
        {navItems.map(({id,NavIcon,label})=>{
          const isPlus=id==="create";
          const active=tab===id;
          return (
            <button key={id} onClick={()=>isPlus?setShowFormat(true):setTab(id)} aria-label={isPlus?"Create new poll":label} aria-current={active?"page":undefined}
              style={{ flex:1,background:"none",border:"none",cursor:"pointer",display:"flex",flexDirection:"column",alignItems:"center",gap:2,padding:"4px 0",position:"relative" }}>
              {isPlus
                ?<div style={{ width:50,height:50,borderRadius:"50%",background:user.brandColor?grad(user.brandColor,B.orange):B.grad,display:"flex",alignItems:"center",justifyContent:"center",boxShadow:`0 4px 18px ${user.brandColor||B.pink}55`,fontSize:26,color:"#fff",marginTop:-22,border:`3px solid ${D.card}` }}>+</div>
                :<>
                  <span style={{ color:active?user.brandColor||B.pink:D.textGray }}><NavIcon/></span>
                  <span style={{ fontFamily:FONT,fontSize:10,fontWeight:active?800:600,color:active?user.brandColor||B.pink:D.textGray }}>{label}</span>
                  {active&&<div style={{ width:18,height:3,background:user.brandColor?grad(user.brandColor,B.orange):B.grad,borderRadius:2 }}/>}
                </>
              }
            </button>
          );
        })}
      </nav>

      {fullIdx!==null&&<FullScreen posts={posts} startIdx={fullIdx} onClose={()=>setFullIdx(null)} onVote={handleVote}/>}
      {showFormat&&<FormatPicker onSelect={f=>{setShowFormat(false);setCreateFmt(f);}} onClose={()=>setShowFormat(false)}/>}
      {createFmt&&<CreatePost format={createFmt} user={user} onPublish={handlePublish} onClose={()=>setCreateFmt(null)}/>}
      {sharePost&&<ShareSheet post={sharePost} onClose={()=>setSharePost(null)}/>}
    </div>
  );
}

export default function App() {
  return (
    <ThemeProvider>
      <TickProvider>
        <ToastProvider>
          <XPProvider>
            <AppInner/>
          </XPProvider>
        </ToastProvider>
      </TickProvider>
    </ThemeProvider>
  );
}
