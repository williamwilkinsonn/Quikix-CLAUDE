// POST CARD  (All poll types + XP integration)
// ═══════════════════════════════════════════════════════════════════════════════
const PostCard = memo(function PostCard({ post, user, onVote, onExpand, onShare, onSave, onRemind, savedIds, remindIds }) {
  const author = USERS[post.authorId]||USERS.me;
  const ac = author.brandColor||B.pink;
  const toast = useToast();
  const { earn } = useXP();
  const { D } = useTheme();
  const [lv, setLv] = useState(()=>[...post.votes]);
  const [voted, setVoted] = useState(post.userVote);
  const [showComments, setShowComments] = useState(false);
  const [comments, setComments] = useState(()=>post.comments||[]);
  const [commentText, setCommentText] = useState("");
  const [charCount, setCharCount] = useState(0);
  const [sliderVal, setSliderVal] = useState(5);
  const [rankItems, setRankItems] = useState(()=>post.options ? [...post.options] : []);
  const [rankDone, setRankDone] = useState(false);
  const MAX_CHARS=280;
  const totalVotes=(lv||[]).reduce((a,b)=>a+b,0);
  const isSaved=(savedIds||[]).includes(post.id);
  const isReminded=(remindIds||[]).includes(post.id);
  const isClosed=post.endsAt<=Date.now();
  const isMyPost=post.authorId==="me";

  const postRef = useRef(post);
  useEffect(()=>{ postRef.current=post; },[post]);

  const vote = useCallback((i) => {
    if (voted!==null||isClosed) return;
    try { navigator.vibrate&&navigator.vibrate(12); } catch {}
    setLv(v=>{ const n=[...v]; n[i]=(n[i]||0)+1; return n; });
    setVoted(i);
    onVote&&onVote(post.id,i,isMyPost);
    earn(10,"Vote cast");
    toast("Vote recorded ✓");
  }, [voted,isClosed,post.id,onVote,isMyPost,earn,toast]);

  const handleShare = async() => {
    if(navigator.share){try{await navigator.share({title:"Quikix Poll",text:post.question,url:`https://quikix.com/q/${post.id}`});toast("Shared!");return;}catch{}}
    onShare&&onShare(post);
  };
  const handleSave   = () => { onSave&&onSave(post.id);     toast(isSaved?"Removed from saved":"Saved 🔖"); };
  const handleRemind = () => { onRemind&&onRemind(post.id); toast(isReminded?"Reminder removed":"Reminder set 🔔"); };
  const handleComment = () => {
    if(!commentText.trim()) return;
    setComments(c=>[...c,{id:uid(),authorId:"me",text:commentText,time:"Just now",likes:0}]);
    setCommentText(""); setCharCount(0);
    earn(5,"Comment posted");
    toast("Comment posted!");
  };

  const ClosedOverlay = () => isClosed ? (
    <div style={{ position:"absolute",inset:0,background:"rgba(0,0,0,0.52)",display:"flex",alignItems:"center",justifyContent:"center",zIndex:3,pointerEvents:"none" }}>
      <div style={{ background:"rgba(255,255,255,0.96)",borderRadius:14,padding:"10px 20px",textAlign:"center" }}>
        <div style={{ fontFamily:FONT,fontWeight:900,fontSize:15,color:B.navy }}>Poll Closed</div>
        <div style={{ fontFamily:FONT,fontSize:13,color:B.textMid,marginTop:2 }}>Final results shown</div>
      </div>
    </div>
  ) : null;

  return (
    <article style={{ background:D.card,borderBottom:`8px solid ${D.bg}`,position:"relative" }}>
      {post.trending&&<div style={{ position:"absolute",top:14,right:14,zIndex:2,background:B.grad,borderRadius:50,padding:"3px 10px",display:"flex",alignItems:"center",gap:4,animation:"trendPulse 2s ease-in-out infinite" }}>
        <span style={{ fontSize:10 }}>🔥</span>
        <span style={{ fontFamily:FONT,fontWeight:800,fontSize:10,color:"#fff" }}>TRENDING · {fmt(totalVotes)}</span>
      </div>}

      {/* Header */}
      <div style={{ padding:"14px 16px 10px",display:"flex",alignItems:"center",gap:10 }}>
        <button onClick={()=>onExpand&&onExpand(post,"profile")} style={{ background:"none",border:"none",cursor:"pointer",padding:0,flexShrink:0 }}>
          <div style={{ width:44,height:44,borderRadius:"50%",background:ac,display:"flex",alignItems:"center",justifyContent:"center",fontFamily:FONT,fontWeight:900,fontSize:16,color:"#fff",border:author.accountType==="business"?`2px solid ${ac}`:"none" }}>{author.avatar}</div>
        </button>
        <div style={{ flex:1,minWidth:0 }}>
          <div style={{ display:"flex",alignItems:"center",gap:5 }}>
            <button onClick={()=>onExpand&&onExpand(post,"profile")} style={{ background:"none",border:"none",padding:0,cursor:"pointer",fontFamily:FONT,fontWeight:800,fontSize:15,color:D.text }}>{author.name}</button>
            {author.verified&&<span style={{ fontSize:12,color:ac }}>✓</span>}
            {author.accountType==="business"&&<span style={{ fontFamily:FONT,fontSize:10,fontWeight:700,color:ac,background:`${ac}18`,padding:"2px 7px",borderRadius:50 }}>Brand</span>}
          </div>
          <div style={{ fontFamily:FONT,fontSize:12,color:D.textMid }}>📍 {author.location}</div>
        </div>
        <div style={{ display:"flex",flexDirection:"column",alignItems:"flex-end",gap:5 }}>
          <Countdown endsAt={post.endsAt}/>
          <div style={{ display:"flex",gap:7,alignItems:"center" }}>
            <button onClick={handleSave}   aria-pressed={isSaved}    style={{ background:"none",border:"none",cursor:"pointer",color:isSaved?B.orange:D.textGray,padding:1 }}><Ic.BookmarkFill/></button>
            <button onClick={handleRemind} aria-pressed={isReminded} style={{ background:"none",border:"none",cursor:"pointer",color:isReminded?B.blue:D.textGray,padding:1 }}><Ic.Bell2/></button>
            <button onClick={handleShare}  aria-label="Share poll"   style={{ width:26,height:26,borderRadius:"50%",border:`1.5px solid ${D.border}`,background:D.surface,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",color:D.textMid }}><Ic.Share/></button>
          </div>
        </div>
      </div>

      <h3 style={{ padding:"0 16px 10px",fontFamily:FONT,fontWeight:700,fontSize:16,color:D.text,lineHeight:1.4,margin:0 }}>{post.question}</h3>

      {/* ── A/B ── */}
      {post.type==="ab"&&post.images&&(
        <div style={{ display:"flex",gap:2,position:"relative" }}>
          <ClosedOverlay/>
          {post.images.slice(0,2).map((img,i)=>(
            <div key={i} style={{ flex:1,position:"relative",overflow:"hidden" }}>
              <button onClick={()=>vote(i)} disabled={voted!==null||isClosed}
                style={{ width:"100%",border:"none",padding:0,cursor:voted!==null||isClosed?"default":"pointer",background:"transparent",display:"block" }}>
                <img src={img} alt={`Option ${i+1}${voted!==null?` — ${pct(lv[i]||0,totalVotes)}%`:""}`} loading="lazy"
                  style={{ width:"100%",height:260,objectFit:"cover",display:"block",transition:"opacity .25s",opacity:voted!==null&&voted!==i?0.45:1 }}/>
              </button>
              {voted!==null&&<div style={{ position:"absolute",inset:0,display:"flex",alignItems:"center",justifyContent:"center",pointerEvents:"none" }}>
                <div style={{ background:voted===i?"rgba(255,255,255,0.96)":"rgba(0,0,0,0.45)",borderRadius:12,padding:"8px 14px",textAlign:"center" }}>
                  <div style={{ fontFamily:FONT,fontWeight:900,fontSize:20,color:voted===i?ac:"#fff" }}>{pct(lv[i]||0,totalVotes)}%</div>
                  <div style={{ fontFamily:FONT,fontSize:11,color:voted===i?B.textMid:"rgba(255,255,255,0.8)",marginTop:2 }}>{voted===i?"✓ Your vote":fmt(lv[i]||0)+" votes"}</div>
                </div>
              </div>}
              <div style={{ position:"absolute",bottom:10,[i===0?"left":"right"]:10,pointerEvents:"none" }}>
                <div style={{ width:50,height:50,borderRadius:"50%",background:voted===i?ac:"rgba(255,255,255,0.93)",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",boxShadow:"0 2px 12px rgba(0,0,0,0.28)" }}>
                  <span style={{ fontSize:9,fontWeight:900,color:voted===i?"#fff":B.pink,fontFamily:FONT,lineHeight:1.1 }}>Q</span>
                  <span style={{ fontSize:10,fontWeight:800,color:voted===i?"#fff":B.navy,fontFamily:FONT,lineHeight:1.1 }}>{voted!==null?`${pct(lv[i]||0,totalVotes)}%`:fmt(lv[i]||0)}</span>
