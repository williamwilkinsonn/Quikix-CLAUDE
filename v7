// GAMIFICATION PAGE — XP, Leaderboard, Achievements, Levels
// ═══════════════════════════════════════════════════════════════════════════════
function GamificationPage() {
  const { xp, level } = useXP();
  const { D } = useTheme();
  const [gtab, setGtab] = useState("leaderboard");
  const nextLevel = LEVELS.find(l=>l.min>xp) || LEVELS[LEVELS.length-1];
  const progress = nextLevel.min===Infinity ? 100 : pct(xp-level.min, nextLevel.min-level.min);
  const xpToNext = nextLevel.min===Infinity ? 0 : nextLevel.min-xp;

  return (
    <div style={{ paddingBottom:100 }}>
      {/* XP Hero */}
      <div style={{ background:B.grad,padding:"24px 20px 28px",position:"relative",overflow:"hidden" }}>
        <div style={{ position:"absolute",top:-40,right:-40,width:180,height:180,borderRadius:"50%",background:"rgba(255,255,255,0.07)",pointerEvents:"none" }}/>
        <div style={{ position:"absolute",bottom:-30,left:-20,width:120,height:120,borderRadius:"50%",background:"rgba(255,255,255,0.05)",pointerEvents:"none" }}/>
        <div style={{ display:"flex",alignItems:"center",gap:16,marginBottom:18,position:"relative" }}>
          <div style={{ width:64,height:64,borderRadius:"50%",background:"rgba(255,255,255,0.2)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:32,flexShrink:0 }}>{level.icon}</div>
          <div style={{ flex:1 }}>
            <div style={{ fontFamily:FONT,fontWeight:900,fontSize:20,color:"#fff",marginBottom:2 }}>{level.label}</div>
            <div style={{ fontFamily:FONT,fontSize:13,color:"rgba(255,255,255,0.8)" }}>
              {fmt(xp)} XP total{xpToNext>0?` · ${fmt(xpToNext)} XP to next level`:" · MAX LEVEL 👑"}
            </div>
          </div>
          <div style={{ fontFamily:FONT,fontWeight:900,fontSize:28,color:"#fff" }}>{fmt(xp)}</div>
        </div>
        <div style={{ background:"rgba(255,255,255,0.2)",borderRadius:8,height:10,marginBottom:6,position:"relative" }}>
          <div style={{ height:"100%",width:`${progress}%`,background:"rgba(255,255,255,0.9)",borderRadius:8,transition:"width .6s ease" }}/>
        </div>
        <div style={{ display:"flex",justifyContent:"space-between" }}>
          <span style={{ fontFamily:FONT,fontSize:11,color:"rgba(255,255,255,0.7)" }}>{level.label} ({fmt(level.min)} XP)</span>
          <span style={{ fontFamily:FONT,fontSize:11,color:"rgba(255,255,255,0.7)" }}>{nextLevel.label} ({fmt(nextLevel.min)} XP)</span>
        </div>
      </div>

      {/* How to earn XP */}
      <div style={{ background:D.card,borderBottom:`1px solid ${D.border}`,padding:"12px 16px" }}>
        <div style={{ fontFamily:FONT,fontWeight:700,fontSize:11,color:D.textMid,marginBottom:8,letterSpacing:0.8 }}>HOW TO EARN XP</div>
        <div style={{ display:"flex",gap:10,overflowX:"auto",scrollbarWidth:"none" }}>
          {[["🗳️","Vote","+10"],["📊","Create","+25"],["💬","Comment","+5"],["🔥","Trending","+100"],["👥","Follower","+2"],["🏆","Ranked","+15"]].map(([icon,label,xpAmt])=>(
            <div key={label} style={{ background:D.surface,border:`1px solid ${D.border}`,borderRadius:12,padding:"8px 12px",textAlign:"center",minWidth:72,flexShrink:0 }}>
              <div style={{ fontSize:18,marginBottom:3 }}>{icon}</div>
              <div style={{ fontFamily:FONT,fontSize:10,color:D.text,fontWeight:700 }}>{label}</div>
              <div style={{ fontFamily:FONT,fontSize:10,color:B.green,fontWeight:800 }}>{xpAmt} XP</div>
            </div>
          ))}
        </div>
      </div>

      {/* Sub-tabs */}
      <div style={{ display:"flex",borderBottom:`1px solid ${D.border}`,background:D.card }}>
        {[["leaderboard","🏆 Board"],["achievements","🎖️ Badges"],["levels","⭐ Levels"]].map(([id,label])=>(
          <button key={id} onClick={()=>setGtab(id)} style={{ flex:1,padding:"12px 4px",border:"none",borderBottom:`2.5px solid ${gtab===id?B.pink:"transparent"}`,background:"transparent",fontFamily:FONT,fontWeight:gtab===id?800:600,fontSize:12,color:gtab===id?B.pink:D.textMid,cursor:"pointer" }}>{label}</button>
        ))}
      </div>

      {gtab==="leaderboard"&&(
        <div style={{ padding:"16px" }}>
          {LEADERBOARD.map((u,i)=>(
            <div key={u.rank} style={{ display:"flex",alignItems:"center",gap:12,padding:"12px 14px",background:u.isMe?`${B.pink}10`:D.card,borderRadius:14,marginBottom:10,border:`1.5px solid ${u.isMe?B.pink:D.border}`,boxShadow:B.shadow }}>
              <div style={{ width:36,height:36,borderRadius:12,background:i===0?B.gold:i===1?B.silver:i===2?B.bronze:D.border,display:"flex",alignItems:"center",justifyContent:"center",fontFamily:FONT,fontWeight:900,fontSize:i<3?18:14,color:i<3?"#fff":D.textMid,flexShrink:0 }}>{u.badge||`#${u.rank}`}</div>
              <div style={{ width:42,height:42,borderRadius:"50%",background:u.color,display:"flex",alignItems:"center",justifyContent:"center",fontFamily:FONT,fontWeight:900,fontSize:16,color:"#fff",flexShrink:0 }}>{u.avatar}</div>
              <div style={{ flex:1 }}>
                <div style={{ fontFamily:FONT,fontWeight:800,fontSize:15,color:D.text }}>
                  {u.name}{u.isMe&&<span style={{ fontFamily:FONT,fontSize:11,color:B.pink,fontWeight:700,marginLeft:6 }}>← You</span>}
                </div>
                <div style={{ fontFamily:FONT,fontSize:12,color:D.textMid }}>{fmt(u.votes)} votes cast</div>
              </div>
              <div style={{ fontFamily:FONT,fontWeight:900,fontSize:18,color:i===0?B.gold:i===1?B.silver:i===2?B.bronze:D.text }}>#{u.rank}</div>
            </div>
          ))}
        </div>
      )}

      {gtab==="achievements"&&(
        <div style={{ padding:"16px" }}>
          <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:12 }}>
            {ACHIEVEMENTS.map(a=>(
              <div key={a.id} style={{ background:a.earned?D.card:D.surface,borderRadius:18,padding:"16px 14px",border:`1.5px solid ${a.earned?B.gold+"55":D.border}`,boxShadow:a.earned?`0 4px 16px ${B.gold}22`:B.shadow,opacity:a.earned?1:0.55,textAlign:"center" }}>
                <div style={{ fontSize:32,marginBottom:8,filter:a.earned?"none":"grayscale(1)" }}>{a.icon}</div>
                <div style={{ fontFamily:FONT,fontWeight:800,fontSize:13,color:D.text,marginBottom:4 }}>{a.title}</div>
                <div style={{ fontFamily:FONT,fontSize:11,color:D.textMid,marginBottom:8,lineHeight:1.4 }}>{a.desc}</div>
                <div style={{ display:"inline-flex",alignItems:"center",gap:4,background:a.earned?`${B.gold}22`:D.border,borderRadius:50,padding:"4px 10px" }}>
                  <span style={{ fontSize:11 }}>⭐</span>
                  <span style={{ fontFamily:FONT,fontWeight:800,fontSize:11,color:a.earned?B.gold:D.textGray }}>{a.xp} XP</span>
                </div>
                {a.earned&&<div style={{ fontFamily:FONT,fontSize:10,color:B.green,fontWeight:700,marginTop:6 }}>✓ Earned</div>}
              </div>
            ))}
          </div>
        </div>
      )}

      {gtab==="levels"&&(
        <div style={{ padding:"16px" }}>
          {LEVELS.map((l,i)=>{
            const reached=xp>=l.min;
            const isCurrent=xp>=l.min&&xp<=l.max;
            return (
              <div key={l.label} style={{ display:"flex",alignItems:"center",gap:14,padding:"14px 16px",background:isCurrent?`${l.color}14`:D.card,borderRadius:16,marginBottom:10,border:`1.5px solid ${isCurrent?l.color+"55":D.border}`,opacity:reached?1:0.45 }}>
                <div style={{ width:52,height:52,borderRadius:"50%",background:reached?l.color:D.border,display:"flex",alignItems:"center",justifyContent:"center",fontSize:26,flexShrink:0 }}>{l.icon}</div>
                <div style={{ flex:1 }}>
                  <div style={{ fontFamily:FONT,fontWeight:800,fontSize:15,color:D.text,marginBottom:2 }}>{l.label}</div>
                  <div style={{ fontFamily:FONT,fontSize:12,color:D.textMid }}>{fmt(l.min)} XP{l.max!==Infinity?` — ${fmt(l.max)} XP`:""}</div>
                </div>
                {isCurrent&&<div style={{ background:l.color,borderRadius:50,padding:"4px 12px",fontFamily:FONT,fontWeight:800,fontSize:11,color:"#fff" }}>Current</div>}
                {reached&&!isCurrent&&<div style={{ fontSize:20,color:B.green }}>✓</div>}
                {!reached&&<div style={{ fontFamily:FONT,fontSize:11,color:D.textGray }}>{fmt(l.min-xp)} XP away</div>}
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}

